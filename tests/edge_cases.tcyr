# edge_cases.tcyr — edge case, boundary, and error path tests
# Covers gaps between the Rust test suite and existing Cyrius tests.
# Target: 150+ new assertions

include "lib/f64_util.cyr"
include "lib/error.cyr"
include "lib/vec2.cyr"
include "lib/vec3.cyr"
include "lib/vec4.cyr"
include "lib/quat.cyr"
include "lib/mat4.cyr"
include "lib/transforms.cyr"
include "lib/color.cyr"
include "lib/geo.cyr"
include "lib/geo_advanced.cyr"
include "lib/calc.cyr"
include "lib/num.cyr"
include "lib/complex.cyr"
include "lib/lie.cyr"
include "lib/diffgeo.cyr"
include "lib/symbolic.cyr"
include "lib/autodiff.cyr"
include "lib/interval.cyr"
include "lib/tensor.cyr"

# ================================================================
# Helper functions (must be defined before alloc_init)
# ================================================================

var LOOSE_TOL = 0x3E45798EE2308C3A;  # ~1e-8

fn assert_f64_eq(a, b, msg) {
    assert(f64_approx_eq(a, b, LOOSE_TOL), msg);
    return 0;
}

# Helpers for calc edge cases
fn _ec_const5(x) { return f64_from(5); }
fn _ec_x2(x) { return f64_mul(x, x); }
fn _ec_identity(x) { return x; }

# Helpers for newton zero-derivative edge case
fn _ec_x2_minus1(x) { return f64_sub(f64_mul(x, x), F64_ONE); }
fn _ec_zero_df(x) { return 0; }

# Helper for bisection same-sign test
fn _ec_x_plus1(x) { return f64_add(x, F64_ONE); }

# Helper for RK4 test: dy/dt = 1 (constant rate)
fn _ec_dydt_const(t, y) { return F64_ONE; }

alloc_init();

# ================================================================
# Vec2/Vec3/Vec4 — Normalize zero vector
# ================================================================
test_group("edge: vec zero-length normalize");

# Vec2 normalize zero → returns zero (not NaN)
var en_v2z = hvec2_normalize(hvec2_zero());
assert_eq(f64_to(HVec2_x(en_v2z)), 0, "v2 norm zero.x=0");
assert_eq(f64_to(HVec2_y(en_v2z)), 0, "v2 norm zero.y=0");

# Vec3 normalize zero → returns zero
var en_v3z = hvec3_normalize(hvec3_zero());
assert_eq(f64_to(HVec3_x(en_v3z)), 0, "v3 norm zero.x=0");
assert_eq(f64_to(HVec3_y(en_v3z)), 0, "v3 norm zero.y=0");
assert_eq(f64_to(HVec3_z(en_v3z)), 0, "v3 norm zero.z=0");

# Vec4 normalize zero → returns zero
var en_v4z = hvec4_normalize(hvec4_zero());
assert_eq(f64_to(HVec4_x(en_v4z)), 0, "v4 norm zero.x=0");
assert_eq(f64_to(HVec4_y(en_v4z)), 0, "v4 norm zero.y=0");
assert_eq(f64_to(HVec4_z(en_v4z)), 0, "v4 norm zero.z=0");
assert_eq(f64_to(HVec4_w(en_v4z)), 0, "v4 norm zero.w=0");

# ================================================================
# Vec3 — Degenerate cross products (parallel vectors)
# ================================================================
test_group("edge: vec3 parallel cross");

# Parallel same direction: (1,0,0) x (2,0,0) = (0,0,0)
var ecr_par = hvec3_cross(hvec3_unit_x(), hvec3_scale(hvec3_unit_x(), F64_TWO));
assert_eq(f64_to(HVec3_x(ecr_par)), 0, "parallel cross.x=0");
assert_eq(f64_to(HVec3_y(ecr_par)), 0, "parallel cross.y=0");
assert_eq(f64_to(HVec3_z(ecr_par)), 0, "parallel cross.z=0");

# Anti-parallel: (1,0,0) x (-1,0,0) = (0,0,0)
var ecr_anti = hvec3_cross(hvec3_unit_x(), hvec3_neg(hvec3_unit_x()));
assert_eq(f64_to(HVec3_x(ecr_anti)), 0, "antiparallel cross.x=0");
assert_eq(f64_to(HVec3_y(ecr_anti)), 0, "antiparallel cross.y=0");
assert_eq(f64_to(HVec3_z(ecr_anti)), 0, "antiparallel cross.z=0");

# Scaled parallel: (3,6,9) x (1,2,3) = (0,0,0)
var ecr_a = hvec3_new(f64_from(3), f64_from(6), f64_from(9));
var ecr_b = hvec3_new(F64_ONE, F64_TWO, f64_from(3));
var ecr_sc = hvec3_cross(ecr_a, ecr_b);
assert_eq(f64_to(HVec3_x(ecr_sc)), 0, "scaled parallel cross.x=0");
assert_eq(f64_to(HVec3_y(ecr_sc)), 0, "scaled parallel cross.y=0");
assert_eq(f64_to(HVec3_z(ecr_sc)), 0, "scaled parallel cross.z=0");

# ================================================================
# Quaternion — Slerp edge cases
# ================================================================
test_group("edge: quat slerp nearly-identical");

# Nearly identical quaternions → exercises threshold/lerp path
var eq_a = hquat_identity();
var eq_tiny = hquat_from_rotation_z(EPSILON_F64);  # tiny angle
var eq_slerp_tiny = hquat_slerp(eq_a, eq_tiny, F64_HALF);
assert_f64_eq(hquat_length(eq_slerp_tiny), F64_ONE, "slerp near-id length=1");
# Should be close to identity
assert_f64_eq(HQuat_w(eq_slerp_tiny), F64_ONE, "slerp near-id w~1");

test_group("edge: quat slerp same quat");

# Slerp between identical quaternions
var eq_same = hquat_slerp(eq_a, eq_a, F64_HALF);
assert_f64_eq(HQuat_w(eq_same), F64_ONE, "slerp same .w=1");
assert_f64_eq(HQuat_x(eq_same), 0, "slerp same .x=0");

test_group("edge: quat slerp opposite");

# Opposite quaternions (q and -q represent same rotation, but dot < 0 → shortest path)
var eq_pos = hquat_from_rotation_z(F64_PI_4);
var eq_neg = hquat_new(f64_neg(HQuat_x(eq_pos)), f64_neg(HQuat_y(eq_pos)),
                       f64_neg(HQuat_z(eq_pos)), f64_neg(HQuat_w(eq_pos)));
var eq_opp = hquat_slerp(eq_pos, eq_neg, F64_HALF);
# Should stay close to eq_pos (they represent the same rotation)
assert_f64_eq(hquat_length(eq_opp), F64_ONE, "slerp opposite length=1");

# ================================================================
# Mat4 — Singular matrix inverse → returns identity (fallback)
# ================================================================
test_group("edge: mat4 singular inverse");

# Zero matrix is singular
var em_zero = m4_new();
var em_inv = m4_inverse(em_zero);
# Fallback should return identity
assert_eq(f64_to(m4_get(em_inv, 0, 0)), 1, "singular inv [0,0]=1");
assert_eq(f64_to(m4_get(em_inv, 1, 1)), 1, "singular inv [1,1]=1");
assert_eq(f64_to(m4_get(em_inv, 2, 2)), 1, "singular inv [2,2]=1");
assert_eq(f64_to(m4_get(em_inv, 3, 3)), 1, "singular inv [3,3]=1");
assert_eq(f64_to(m4_get(em_inv, 0, 1)), 0, "singular inv [0,1]=0");

test_group("edge: mat4 determinant zero");

# Determinant of zero matrix = 0
assert_eq(f64_to(m4_determinant(em_zero)), 0, "det(zero matrix)=0");

# Determinant of identity = 1
assert_eq(f64_to(m4_determinant(m4_identity())), 1, "det(I)=1");

# Rank-deficient matrix (duplicate rows) has det=0
var em_dup = m4_new();
m4_set(em_dup, 0, 0, F64_ONE); m4_set(em_dup, 0, 1, F64_TWO);
m4_set(em_dup, 1, 0, F64_ONE); m4_set(em_dup, 1, 1, F64_TWO);
assert_eq(f64_to(m4_determinant(em_dup)), 0, "det(rank deficient)=0");

# ================================================================
# Transform compose with identity = self
# ================================================================
test_group("edge: transform compose identity");

var et_t = t3d_new(hvec3_new(f64_from(3), f64_from(4), f64_from(5)),
                   hquat_from_rotation_y(F64_PI_4), hvec3_one());
var et_id = t3d_identity();

# compose(t, id) applied to origin ~ t applied to origin
var et_ti = t3d_compose(et_t, et_id);
var et_p1 = t3d_apply(et_t, hvec3_zero());
var et_p2 = t3d_apply(et_ti, hvec3_zero());
assert_f64_eq(HVec3_x(et_p1), HVec3_x(et_p2), "compose id .x match");
assert_f64_eq(HVec3_y(et_p1), HVec3_y(et_p2), "compose id .y match");
assert_f64_eq(HVec3_z(et_p1), HVec3_z(et_p2), "compose id .z match");

# compose(id, t) applied to origin ~ t applied to origin
var et_it = t3d_compose(et_id, et_t);
var et_p3 = t3d_apply(et_it, hvec3_zero());
assert_f64_eq(HVec3_x(et_p1), HVec3_x(et_p3), "id compose .x match");
assert_f64_eq(HVec3_y(et_p1), HVec3_y(et_p3), "id compose .y match");
assert_f64_eq(HVec3_z(et_p1), HVec3_z(et_p3), "id compose .z match");

# ================================================================
# Geo — Ray parallel to plane → miss
# ================================================================
test_group("edge: geo ray-plane parallel");

var eg_plane = geo_plane_from_point_normal(hvec3_zero(), hvec3_unit_y());
var eg_par_ray = geo_ray_new(hvec3_new(0, f64_from(5), 0), hvec3_unit_x());
assert_eq(geo_ray_plane(eg_par_ray, eg_plane), 0, "ray parallel plane miss");

# Ray in plane (origin on plane, direction along plane)
var eg_in_ray = geo_ray_new(hvec3_zero(), hvec3_unit_z());
assert_eq(geo_ray_plane(eg_in_ray, eg_plane), 0, "ray in plane miss");

# ================================================================
# Geo — Ray behind sphere → miss
# ================================================================
test_group("edge: geo ray-sphere behind");

# Sphere behind ray origin: sphere at z=-5, ray pointing +z
var eg_sph_behind = geo_sphere_new(hvec3_new(0, 0, f64_neg(f64_from(5))), F64_ONE);
var eg_ray_fwd = geo_ray_new(hvec3_zero(), hvec3_unit_z());
assert_eq(geo_ray_sphere(eg_ray_fwd, eg_sph_behind), 0, "ray behind sphere miss");

# ================================================================
# Geo — Ray tangent to sphere
# ================================================================
test_group("edge: geo ray-sphere tangent");

# Sphere at (0,0,5), r=1. Ray from (1,0,0) going +z → distance to axis = 1 = r
var eg_sph = geo_sphere_new(hvec3_new(0, 0, f64_from(5)), F64_ONE);
var eg_tang_ray = geo_ray_new(hvec3_new(F64_ONE, 0, 0), hvec3_unit_z());
var eg_tang_t = geo_ray_sphere(eg_tang_ray, eg_sph);
# Tangent should be a hit (discriminant=0 → single intersection)
assert(eg_tang_t != 0, "ray tangent sphere hit");
# t should be ~5 (closest approach at z=5)
assert_eq(f64_to(eg_tang_t), 5, "ray tangent sphere t=5");

# ================================================================
# Geo — AABB touching (shared face) → overlap
# ================================================================
test_group("edge: geo aabb touching/contained");

var eg_aabb1 = geo_aabb_new(hvec3_zero(), hvec3_new(F64_ONE, F64_ONE, F64_ONE));

# Touching: shares a face at x=1
var eg_aabb_touch = geo_aabb_new(hvec3_new(F64_ONE, 0, 0),
                                 hvec3_new(F64_TWO, F64_ONE, F64_ONE));
assert_eq(geo_aabb_aabb(eg_aabb1, eg_aabb_touch), 1, "aabb touching overlap");

# Contained: small AABB inside larger
var eg_aabb_small = geo_aabb_new(hvec3_new(F64_HALF, F64_HALF, F64_HALF),
                                 hvec3_new(F64_HALF, F64_HALF, F64_HALF));
assert_eq(geo_aabb_aabb(eg_aabb1, eg_aabb_small), 1, "aabb contained overlap");

# ================================================================
# Geo — Sphere concentric → overlap
# ================================================================
test_group("edge: geo sphere concentric");

var eg_s1 = geo_sphere_new(hvec3_zero(), F64_ONE);
var eg_s2 = geo_sphere_new(hvec3_zero(), F64_TWO);
assert_eq(geo_sphere_sphere(eg_s1, eg_s2), 1, "sphere concentric overlap");

# Same sphere
assert_eq(geo_sphere_sphere(eg_s1, eg_s1), 1, "sphere self overlap");

# ================================================================
# Geo — Closest point on sphere when point is at center → fallback
# ================================================================
test_group("edge: geo closest point at center");

var eg_sph_unit = geo_sphere_new(hvec3_zero(), F64_ONE);
var eg_cp = geo_closest_point_on_sphere(eg_sph_unit, hvec3_zero());
# Fallback: should return center + (r,0,0) → (1,0,0)
assert_eq(f64_to(HVec3_x(eg_cp)), 1, "closest sphere at center.x=1");
assert_eq(f64_to(HVec3_y(eg_cp)), 0, "closest sphere at center.y=0");

# ================================================================
# Geo — Degenerate triangle (zero area)
# ================================================================
test_group("edge: geo degenerate triangle");

# Collinear points: (0,0,0), (1,0,0), (2,0,0)
var eg_degen = geo_triangle_new(hvec3_zero(),
                                hvec3_new(F64_ONE, 0, 0),
                                hvec3_new(F64_TWO, 0, 0));
var eg_degen_area = geo_triangle_area(eg_degen);
assert_eq(f64_to(eg_degen_area), 0, "degenerate triangle area=0");

# ================================================================
# Geo — Segment zero length
# ================================================================
test_group("edge: geo segment zero length");

var eg_seg0 = geo_segment_new(hvec3_new(F64_ONE, F64_TWO, f64_from(3)),
                              hvec3_new(F64_ONE, F64_TWO, f64_from(3)));
assert_eq(f64_to(geo_segment_length(eg_seg0)), 0, "zero segment length=0");

# Closest point on zero-length segment = the point itself
var eg_seg0_cp = geo_segment_closest_point(eg_seg0, hvec3_zero());
assert_eq(f64_to(HVec3_x(eg_seg0_cp)), 1, "zero seg closest.x");
assert_eq(f64_to(HVec3_y(eg_seg0_cp)), 2, "zero seg closest.y");

# Direction of zero-length segment → fallback to unit_x
var eg_seg0_dir = geo_segment_direction(eg_seg0);
assert_eq(f64_to(HVec3_x(eg_seg0_dir)), 1, "zero seg dir.x=1");
assert_eq(f64_to(HVec3_y(eg_seg0_dir)), 0, "zero seg dir.y=0");

# ================================================================
# Calc — Simpson with 0 steps → error
# ================================================================
test_group("edge: calc simpson 0 steps");

var ec_out = alloc(8);
var ec_rc_0 = calc_integral_simpson(&_ec_x2, 0, F64_ONE, 0, ec_out);
assert_eq(ec_rc_0, ERR_ZERO_STEPS, "simpson 0 steps → err");

# Simpson with 1 step (odd → rounds to 2)
var ec_rc_1 = calc_integral_simpson(&_ec_const5, 0, F64_ONE, 1, ec_out);
assert_eq(ec_rc_1, 0, "simpson 1 step ok");
assert_eq(f64_to(load64(ec_out)), 5, "simpson 1 step const=5");

# ================================================================
# Calc — Derivative of constant = 0
# ================================================================
test_group("edge: calc derivative constant");

var ec_dc = calc_derivative(&_ec_const5, F64_ONE, F64_ONE);
assert_eq(f64_to(ec_dc), 0, "deriv const = 0");

# Derivative of identity at x=0 with h=1: (1 - (-1))/2 = 1
var ec_did = calc_derivative(&_ec_identity, 0, F64_ONE);
assert_eq(f64_to(ec_did), 1, "deriv identity = 1");

# ================================================================
# Calc — Bezier endpoints
# ================================================================
test_group("edge: calc bezier endpoints");

# Cubic bezier at t=0 and t=1
var ec_bz0 = hvec2_new(f64_from(0), f64_from(0));
var ec_bz1 = hvec2_new(f64_from(1), f64_from(5));
var ec_bz2 = hvec2_new(f64_from(4), f64_from(5));
var ec_bz3 = hvec2_new(f64_from(5), f64_from(0));

var ec_c0 = calc_bezier_cubic_2d(ec_bz0, ec_bz1, ec_bz2, ec_bz3, 0);
assert_eq(f64_to(HVec2_x(ec_c0)), 0, "cubic bezier t=0 x");
assert_eq(f64_to(HVec2_y(ec_c0)), 0, "cubic bezier t=0 y");

var ec_c1 = calc_bezier_cubic_2d(ec_bz0, ec_bz1, ec_bz2, ec_bz3, F64_ONE);
assert_eq(f64_to(HVec2_x(ec_c1)), 5, "cubic bezier t=1 x");
assert_eq(f64_to(HVec2_y(ec_c1)), 0, "cubic bezier t=1 y");

# 3D cubic bezier endpoints
var ec_b3_0 = hvec3_new(0, 0, 0);
var ec_b3_1 = hvec3_new(F64_ONE, f64_from(3), 0);
var ec_b3_2 = hvec3_new(F64_TWO, f64_from(3), 0);
var ec_b3_3 = hvec3_new(f64_from(3), 0, 0);

var ec_bc0 = calc_bezier_cubic_3d(ec_b3_0, ec_b3_1, ec_b3_2, ec_b3_3, 0);
assert_eq(f64_to(HVec3_x(ec_bc0)), 0, "3d bezier t=0 x");
var ec_bc1 = calc_bezier_cubic_3d(ec_b3_0, ec_b3_1, ec_b3_2, ec_b3_3, F64_ONE);
assert_eq(f64_to(HVec3_x(ec_bc1)), 3, "3d bezier t=1 x");
assert_eq(f64_to(HVec3_y(ec_bc1)), 0, "3d bezier t=1 y");

# ================================================================
# Num — Newton with zero derivative → error
# ================================================================
test_group("edge: num newton zero deriv");

var en_out = alloc(8);
var en_rc = num_newton(&_ec_x2_minus1, &_ec_zero_df, F64_TWO, EPSILON_F64, 100, en_out);
assert_eq(en_rc, ERR_DIVISION_BY_ZERO, "newton zero deriv err");

# ================================================================
# Num — Bisection same sign → error
# ================================================================
test_group("edge: num bisection same sign");

var en_bis_out = alloc(8);
# x+1 is positive on [1, 2] → same sign
var en_bis_rc = num_bisection(&_ec_x_plus1, F64_ONE, F64_TWO, EPSILON_F64, 100, en_bis_out);
assert_neq(en_bis_rc, 0, "bisection same sign err");

# ================================================================
# Num — GCD edge cases
# ================================================================
test_group("edge: num gcd boundary");

assert_eq(num_gcd(0, 5), 5, "gcd(0,5)=5");
assert_eq(num_gcd(5, 0), 5, "gcd(5,0)=5");
assert_eq(num_gcd(0, 0), 0, "gcd(0,0)=0");
assert_eq(num_gcd(1, 1), 1, "gcd(1,1)=1");
assert_eq(num_gcd(1, 100), 1, "gcd(1,100)=1");

# ================================================================
# Num — Modpow edge cases
# ================================================================
test_group("edge: num modpow boundary");

assert_eq(num_modpow(7, 0, 13), 1, "modpow exp=0 → 1");
assert_eq(num_modpow(7, 1, 13), 7, "modpow exp=1 → base");
assert_eq(num_modpow(999, 0, 5), 1, "modpow large^0 → 1");
assert_eq(num_modpow(5, 3, 1), 0, "modpow mod=1 → 0");

# ================================================================
# Num — is_prime(0) = 0, is_prime(1) = 0
# ================================================================
test_group("edge: num primality boundary");

assert_eq(num_is_prime(0), 0, "is_prime(0)=0");
assert_eq(num_is_prime(1), 0, "is_prime(1)=0");
assert_eq(num_is_prime(2), 1, "is_prime(2)=1");
assert_eq(num_is_prime(4), 0, "is_prime(4)=0");

# ================================================================
# Num — Sieve(0) and Sieve(1) → empty vec
# ================================================================
test_group("edge: num sieve boundary");

var en_s0 = num_sieve(0);
assert_eq(vec_len(en_s0), 0, "sieve(0) empty");

var en_s1 = num_sieve(1);
assert_eq(vec_len(en_s1), 0, "sieve(1) empty");

var en_s2 = num_sieve(2);
assert_eq(vec_len(en_s2), 1, "sieve(2) has 1 prime");
assert_eq(vec_get(en_s2, 0), 2, "sieve(2) first=2");

# ================================================================
# Num — Kahan sum edge cases
# ================================================================
test_group("edge: num kahan empty/single");

# Empty sum → 0
var en_kdata = alloc(8);
store64(en_kdata, f64_from(42));
var en_k0 = num_kahan_sum(en_kdata, 0);
assert_eq(f64_to(en_k0), 0, "kahan empty=0");

# Single element
var en_k1 = num_kahan_sum(en_kdata, 1);
assert_eq(f64_to(en_k1), 42, "kahan single=42");

# Neumaier empty
var en_n0 = num_neumaier_sum(en_kdata, 0);
assert_eq(f64_to(en_n0), 0, "neumaier empty=0");

# ================================================================
# Complex — Division by zero → large result
# ================================================================
test_group("edge: complex div by zero");

var ec_a = cx_new(f64_from(3), f64_from(4));
var ec_zero = cx_zero();
var ec_div0 = cx_div(ec_a, ec_zero);
# Division by zero produces very large values (not checked exactly, just non-zero)
# The re or im should be non-zero and large
assert(ec_div0 != 0, "cx div by zero produces result");

# ================================================================
# Complex — cx_abs(0) = 0
# ================================================================
test_group("edge: complex abs/conj boundary");

assert_eq(f64_to(cx_abs(cx_zero())), 0, "cx_abs(0+0i)=0");
assert_eq(f64_to(cx_abs(cx_one())), 1, "cx_abs(1+0i)=1");
assert_eq(f64_to(cx_abs(cx_i())), 1, "cx_abs(0+i)=1");

# cx_conj of purely real → same
var ec_real = cx_real(f64_from(7));
var ec_rc = cx_conj(ec_real);
assert_eq(f64_to(HComplex_re(ec_rc)), 7, "conj real.re=7");
assert_eq(f64_to(HComplex_im(ec_rc)), 0, "conj real.im=0");

# ================================================================
# Complex — Pauli anticommutator {σi, σi} = 2I
# ================================================================
test_group("edge: pauli anticommutator");

var ep_sx = pauli_x();
var ep_anti_xx = cmat_anticommutator(ep_sx, ep_sx);
# {σx, σx} = 2I → trace = 4 (2*2), and [0,0] = 2+0i
var ep_axx00 = cmat_get(ep_anti_xx, 0, 0);
assert_eq(f64_to(HComplex_re(ep_axx00)), 2, "{sx,sx}_00.re=2");
assert_eq(f64_to(HComplex_im(ep_axx00)), 0, "{sx,sx}_00.im=0");
var ep_axx01 = cmat_get(ep_anti_xx, 0, 1);
assert_eq(f64_to(HComplex_re(ep_axx01)), 0, "{sx,sx}_01.re=0");
var ep_axx_tr = cmat_trace(ep_anti_xx);
assert_eq(f64_to(HComplex_re(ep_axx_tr)), 4, "{sx,sx} trace=4");

# {σy, σy} = 2I
var ep_sy = pauli_y();
var ep_anti_yy = cmat_anticommutator(ep_sy, ep_sy);
var ep_ayy_tr = cmat_trace(ep_anti_yy);
assert_eq(f64_to(HComplex_re(ep_ayy_tr)), 4, "{sy,sy} trace=4");

# {σz, σz} = 2I
var ep_sz = pauli_z();
var ep_anti_zz = cmat_anticommutator(ep_sz, ep_sz);
var ep_azz_tr = cmat_trace(ep_anti_zz);
assert_eq(f64_to(HComplex_re(ep_azz_tr)), 4, "{sz,sz} trace=4");

# {σx, σy} = 0 (different Paulis anticommute to zero)
var ep_anti_xy = cmat_anticommutator(ep_sx, ep_sy);
var ep_axy_tr = cmat_trace(ep_anti_xy);
assert_eq(f64_to(HComplex_re(ep_axy_tr)), 0, "{sx,sy} trace=0");

# ================================================================
# Autodiff — Dual constant derivative = 0
# ================================================================
test_group("edge: autodiff constant");

var ea_c = dual_const(f64_from(42));
assert_eq(f64_to(Dual_val(ea_c)), 42, "dual const val=42");
assert_eq(f64_to(Dual_deriv(ea_c)), 0, "dual const deriv=0");

# Operations on constants: c + c → val, deriv=0
var ea_cc = dual_add(dual_const(f64_from(3)), dual_const(f64_from(4)));
assert_eq(f64_to(Dual_val(ea_cc)), 7, "const+const val=7");
assert_eq(f64_to(Dual_deriv(ea_cc)), 0, "const+const deriv=0");

# Const * const
var ea_cm = dual_mul(dual_const(f64_from(3)), dual_const(f64_from(4)));
assert_eq(f64_to(Dual_val(ea_cm)), 12, "const*const val=12");
assert_eq(f64_to(Dual_deriv(ea_cm)), 0, "const*const deriv=0");

# ================================================================
# Autodiff — Chain rule: sin(x^2) at x=0
# ================================================================
test_group("edge: autodiff chain rule");

# f(x) = sin(x^2) at x=0: val = sin(0) = 0, deriv = cos(0)*2*0 = 0
var ea_x0 = dual_var(0);
var ea_x0sq = dual_mul(ea_x0, ea_x0);
var ea_sinx2 = dual_sin(ea_x0sq);
assert_eq(f64_to(Dual_val(ea_sinx2)), 0, "sin(x^2) at 0 val=0");
assert_eq(f64_to(Dual_deriv(ea_sinx2)), 0, "sin(x^2) at 0 deriv=0");

# f(x) = sin(x^2) at x=1: val = sin(1), deriv = cos(1)*2*1
var ea_x1 = dual_var(F64_ONE);
var ea_x1sq = dual_mul(ea_x1, ea_x1);
var ea_sinx2_1 = dual_sin(ea_x1sq);
# sin(1) ~ 0.841
var ea_sv = f64_to(f64_round(f64_mul(Dual_val(ea_sinx2_1), f64_from(1000))));
assert_eq(ea_sv, 841, "sin(1) * 1000 ~ 841");
# deriv = 2*cos(1) ~ 2*0.5403 ~ 1.0806
var ea_sd = f64_to(f64_round(f64_mul(Dual_deriv(ea_sinx2_1), f64_from(1000))));
assert_eq(ea_sd, 1081, "2cos(1) * 1000 ~ 1081");

# ================================================================
# Interval — Point interval width = 0
# ================================================================
test_group("edge: interval point/degenerate");

var ei_pt = ivl_point(f64_from(7));
assert_eq(f64_to(ivl_width(ei_pt)), 0, "point ivl width=0");
assert_eq(f64_to(ivl_midpoint(ei_pt)), 7, "point ivl mid=7");
assert_eq(ivl_contains(ei_pt, f64_from(7)), 1, "point ivl contains self");
assert_eq(ivl_contains(ei_pt, f64_from(8)), 0, "point ivl not contain other");

# Degenerate interval (lo = hi)
var ei_degen = ivl_new(f64_from(5), f64_from(5));
assert_eq(f64_to(ivl_width(ei_degen)), 0, "degenerate width=0");
assert_eq(f64_to(ivl_midpoint(ei_degen)), 5, "degenerate mid=5");

# ================================================================
# Interval — Abs of interval containing zero
# ================================================================
test_group("edge: interval abs with zero");

# [-3, 2]: abs should be [0, 3] since it spans zero
var ei_neg = ivl_new(f64_neg(f64_from(3)), F64_TWO);
var ei_abs = ivl_abs(ei_neg);
assert_eq(f64_to(Interval_lo(ei_abs)), 0, "abs[-3,2] lo=0");
assert_eq(f64_to(Interval_hi(ei_abs)), 3, "abs[-3,2] hi=3");

# Fully negative: [-5, -2]: abs = [2, 5]
var ei_neg2 = ivl_new(f64_neg(f64_from(5)), f64_neg(F64_TWO));
var ei_abs2 = ivl_abs(ei_neg2);
assert_eq(f64_to(Interval_lo(ei_abs2)), 2, "abs[-5,-2] lo=2");
assert_eq(f64_to(Interval_hi(ei_abs2)), 5, "abs[-5,-2] hi=5");

# Fully positive: [2, 5]: abs = [2, 5]
var ei_pos = ivl_new(F64_TWO, f64_from(5));
var ei_abs3 = ivl_abs(ei_pos);
assert_eq(f64_to(Interval_lo(ei_abs3)), 2, "abs[2,5] lo=2");
assert_eq(f64_to(Interval_hi(ei_abs3)), 5, "abs[2,5] hi=5");

# ================================================================
# Symbolic — Differentiate constant → const(0)
# ================================================================
test_group("edge: symbolic diff const");

var es_c = expr_const(f64_from(99));
var es_dc = expr_diff(es_c, str_from("x"));
assert_eq(expr_tag(es_dc), EXPR_CONST, "diff const → const");
var es_empty = vec_new();
assert_eq(f64_to(expr_eval(es_dc, es_empty)), 0, "diff const eval=0");

# ================================================================
# Symbolic — Simplify nested: 0 + (1 * x) → x
# ================================================================
test_group("edge: symbolic simplify nested");

var es_x = expr_var(str_from("x"));
var es_one_x = expr_mul(expr_const(F64_ONE), es_x);
var es_zero_plus = expr_add(expr_const(0), es_one_x);
var es_simp = expr_simplify(es_zero_plus);
# After simplification: 0+(1*x) → should simplify to x (EXPR_VAR)
assert_eq(expr_tag(es_simp), EXPR_VAR, "0+(1*x) → var");

# Nested: (0 * x) + x → x
var es_zero_x = expr_mul(expr_const(0), es_x);
var es_plus_x = expr_add(es_zero_x, es_x);
var es_simp2 = expr_simplify(es_plus_x);
assert_eq(expr_tag(es_simp2), EXPR_VAR, "(0*x)+x → var");

# ================================================================
# Symbolic — Evaluate with missing variable (error resilience)
# ================================================================
# edge: symbolic eval undefined var — SKIPPED
# expr_eval aborts on undefined variables (by design, not a fallback)

# ================================================================
# Mat4 — Transpose of identity = identity
# ================================================================
test_group("edge: mat4 transpose identity");

var em_ti = m4_transpose(m4_identity());
assert_eq(f64_to(m4_get(em_ti, 0, 0)), 1, "transpose I [0,0]=1");
assert_eq(f64_to(m4_get(em_ti, 0, 1)), 0, "transpose I [0,1]=0");
assert_eq(f64_to(m4_get(em_ti, 3, 3)), 1, "transpose I [3,3]=1");

# ================================================================
# Mat4 — I * I = I
# ================================================================
test_group("edge: mat4 mul identity");

var em_ii = m4_mul(m4_identity(), m4_identity());
assert_eq(f64_to(m4_get(em_ii, 0, 0)), 1, "I*I [0,0]=1");
assert_eq(f64_to(m4_get(em_ii, 1, 1)), 1, "I*I [1,1]=1");
assert_eq(f64_to(m4_get(em_ii, 0, 1)), 0, "I*I [0,1]=0");
assert_eq(f64_to(m4_get(em_ii, 3, 0)), 0, "I*I [3,0]=0");

# ================================================================
# Autodiff — neg and sub
# ================================================================
test_group("edge: autodiff neg/sub");

# neg(x) at x=5: val=-5, deriv=-1
var ea_n = dual_neg(dual_var(f64_from(5)));
assert_eq(f64_to(Dual_val(ea_n)), (0 - 5), "neg(x) val=-5");
assert_eq(f64_to(Dual_deriv(ea_n)), (0 - 1), "neg(x) deriv=-1");

# sub(x, 3) at x=5: val=2, deriv=1
var ea_sub = dual_sub(dual_var(f64_from(5)), dual_const(f64_from(3)));
assert_eq(f64_to(Dual_val(ea_sub)), 2, "x-3 val=2");
assert_eq(f64_to(Dual_deriv(ea_sub)), 1, "x-3 deriv=1");

# ================================================================
# Easing — Midpoint values
# ================================================================
test_group("edge: easing midpoints");

# ease_in(0.5) = 0.25
var ee_in = f64_to(f64_round(f64_mul(ease_in(F64_HALF), f64_from(100))));
assert_eq(ee_in, 25, "ease_in(0.5)*100=25");

# ease_out(0.5) = 0.75
var ee_out = f64_to(f64_round(f64_mul(ease_out(F64_HALF), f64_from(100))));
assert_eq(ee_out, 75, "ease_out(0.5)*100=75");

# ease_in_out(0.5) = 0.5
var ee_io = f64_to(f64_round(f64_mul(ease_in_out(F64_HALF), f64_from(100))));
assert_eq(ee_io, 50, "ease_in_out(0.5)*100=50");

# ================================================================
# Num — RK4 basic test
# ================================================================
test_group("edge: num rk4");

# dy/dt = 1 (constant), y(0)=0, dt=1 → y(1) = 1
var erx = num_rk4(&_ec_dydt_const, 0, 0, F64_ONE);
assert_eq(f64_to(erx), 1, "rk4 const dy/dt=1 → y=1");

# ================================================================
# Complex — cx_mul with zero = zero
# ================================================================
test_group("edge: complex zero mul");

var ec_z = cx_mul(cx_new(f64_from(5), f64_from(3)), cx_zero());
assert_eq(f64_to(HComplex_re(ec_z)), 0, "cx mul zero re=0");
assert_eq(f64_to(HComplex_im(ec_z)), 0, "cx mul zero im=0");

# cx_add with zero = self
var ec_az = cx_add(cx_new(f64_from(7), f64_from(2)), cx_zero());
assert_eq(f64_to(HComplex_re(ec_az)), 7, "cx add zero re=7");
assert_eq(f64_to(HComplex_im(ec_az)), 2, "cx add zero im=2");

# ================================================================
# Interval — Mul with negative intervals
# ================================================================
test_group("edge: interval negative mul");

# [-2, -1] * [3, 4] = [-8, -3]
var ei_na = ivl_new(f64_neg(F64_TWO), f64_neg(F64_ONE));
var ei_nb = ivl_new(f64_from(3), f64_from(4));
var ei_nm = ivl_mul(ei_na, ei_nb);
assert_eq(f64_to(Interval_lo(ei_nm)), (0 - 8), "neg*pos ivl lo=-8");
assert_eq(f64_to(Interval_hi(ei_nm)), (0 - 3), "neg*pos ivl hi=-3");

# ================================================================
# Vec3 — Distance symmetry
# ================================================================
test_group("edge: vec3 distance symmetry");

var ed_a = hvec3_new(F64_ONE, F64_TWO, f64_from(3));
var ed_b = hvec3_new(f64_from(4), f64_from(5), f64_from(6));
assert_f64_eq(hvec3_distance(ed_a, ed_b), hvec3_distance(ed_b, ed_a), "distance symmetric");

