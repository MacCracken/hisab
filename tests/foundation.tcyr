# foundation.tcyr — exhaustive tests for foundation types (vec2, vec3, vec4, quat, mat4)
# Ported from the Rust test suite (~100 tests)

include "lib/f64_util.cyr"
include "lib/error.cyr"
include "lib/vec2.cyr"
include "lib/vec3.cyr"
include "lib/vec4.cyr"
include "lib/quat.cyr"
include "lib/mat4.cyr"

alloc_init();

# Tolerance for floating point comparisons
var TOL = f64_from(1);  # 1e-10 is too tight for bit patterns; we use manual checks
# We use f64_approx_eq from f64_util.cyr with a reasonable epsilon
var LOOSE_TOL = 0x3E45798EE2308C3A;  # ~1e-8
var TIGHT_TOL = EPSILON_F64;

# Helper: assert two f64 values are approximately equal
fn assert_f64_eq(a, b, msg) {
    assert(f64_approx_eq(a, b, LOOSE_TOL), msg);
    return 0;
}

# ================================================================
# Vec2 — Construction
# ================================================================
test_group("vec2 construction");

# zero
var v2z = hvec2_zero();
assert_eq(f64_to(HVec2_x(v2z)), 0, "v2 zero.x");
assert_eq(f64_to(HVec2_y(v2z)), 0, "v2 zero.y");

# one
var v2o = hvec2_one();
assert_eq(f64_to(HVec2_x(v2o)), 1, "v2 one.x");
assert_eq(f64_to(HVec2_y(v2o)), 1, "v2 one.y");

# new
var v2a = hvec2_new(f64_from(3), f64_from(4));
assert_eq(f64_to(HVec2_x(v2a)), 3, "v2 new.x");
assert_eq(f64_to(HVec2_y(v2a)), 4, "v2 new.y");

# splat
var v2s = hvec2_splat(f64_from(7));
assert_eq(f64_to(HVec2_x(v2s)), 7, "v2 splat.x");
assert_eq(f64_to(HVec2_y(v2s)), 7, "v2 splat.y");

# ================================================================
# Vec2 — Arithmetic
# ================================================================
test_group("vec2 arithmetic");

var v2b = hvec2_new(f64_from(1), f64_from(2));

# add
var v2add = hvec2_add(v2a, v2b);
assert_eq(f64_to(HVec2_x(v2add)), 4, "v2 add.x");
assert_eq(f64_to(HVec2_y(v2add)), 6, "v2 add.y");

# sub
var v2sub = hvec2_sub(v2a, v2b);
assert_eq(f64_to(HVec2_x(v2sub)), 2, "v2 sub.x");
assert_eq(f64_to(HVec2_y(v2sub)), 2, "v2 sub.y");

# mul (component-wise)
var v2mul = hvec2_mul(v2a, v2b);
assert_eq(f64_to(HVec2_x(v2mul)), 3, "v2 mul.x");
assert_eq(f64_to(HVec2_y(v2mul)), 8, "v2 mul.y");

# scale
var v2sc = hvec2_scale(v2a, f64_from(2));
assert_eq(f64_to(HVec2_x(v2sc)), 6, "v2 scale.x");
assert_eq(f64_to(HVec2_y(v2sc)), 8, "v2 scale.y");

# neg
var v2neg = hvec2_neg(v2a);
assert_eq(f64_to(HVec2_x(v2neg)), (0 - 3), "v2 neg.x");
assert_eq(f64_to(HVec2_y(v2neg)), (0 - 4), "v2 neg.y");

# ================================================================
# Vec2 — Products and Norms
# ================================================================
test_group("vec2 products/norms");

# dot: (3,4).(1,2) = 3+8 = 11
var v2dot = hvec2_dot(v2a, v2b);
assert_eq(f64_to(v2dot), 11, "v2 dot");

# dot with self: (3,4).(3,4) = 9+16 = 25
assert_eq(f64_to(hvec2_dot(v2a, v2a)), 25, "v2 dot self");

# length_sq: (3,4) = 25
assert_eq(f64_to(hvec2_length_sq(v2a)), 25, "v2 length_sq");

# length: (3,4) = 5 (3-4-5 triangle)
assert_eq(f64_to(hvec2_length(v2a)), 5, "v2 length 3-4-5");

# length of (0,0)
assert_eq(f64_to(hvec2_length(hvec2_zero())), 0, "v2 length zero");

# length of (1,0)
assert_eq(f64_to(hvec2_length(hvec2_new(F64_ONE, 0))), 1, "v2 length unit");

# normalize: (3,4)/5 = (0.6, 0.8), length should be 1
var v2norm = hvec2_normalize(v2a);
var v2norm_len = hvec2_length(v2norm);
assert_f64_eq(v2norm_len, F64_ONE, "v2 normalize length=1");

# normalize components: 3/5=0.6, 4/5=0.8
var v2norm_x_10 = f64_to(f64_round(f64_mul(HVec2_x(v2norm), f64_from(10))));
assert_eq(v2norm_x_10, 6, "v2 normalize.x=0.6");
var v2norm_y_10 = f64_to(f64_round(f64_mul(HVec2_y(v2norm), f64_from(10))));
assert_eq(v2norm_y_10, 8, "v2 normalize.y=0.8");

# normalize zero vector returns zero
var v2norm_z = hvec2_normalize(hvec2_zero());
assert_eq(f64_to(HVec2_x(v2norm_z)), 0, "v2 normalize zero.x");
assert_eq(f64_to(HVec2_y(v2norm_z)), 0, "v2 normalize zero.y");

# distance: dist((3,4),(1,2)) = length((2,2)) = sqrt(8) ~ 2.828
var v2dist = hvec2_distance(v2a, v2b);
var v2dist_1000 = f64_to(f64_round(f64_mul(v2dist, f64_from(1000))));
assert_eq(v2dist_1000, 2828, "v2 distance");

# distance to self = 0
assert_eq(f64_to(hvec2_distance(v2a, v2a)), 0, "v2 distance self=0");

# ================================================================
# Vec2 — Interpolation
# ================================================================
test_group("vec2 lerp");

var v2la = hvec2_new(f64_from(0), f64_from(0));
var v2lb = hvec2_new(f64_from(10), f64_from(20));

# lerp t=0 returns a
var v2l0 = hvec2_lerp(v2la, v2lb, 0);
assert_eq(f64_to(HVec2_x(v2l0)), 0, "v2 lerp t=0 .x");
assert_eq(f64_to(HVec2_y(v2l0)), 0, "v2 lerp t=0 .y");

# lerp t=1 returns b
var v2l1 = hvec2_lerp(v2la, v2lb, F64_ONE);
assert_eq(f64_to(HVec2_x(v2l1)), 10, "v2 lerp t=1 .x");
assert_eq(f64_to(HVec2_y(v2l1)), 20, "v2 lerp t=1 .y");

# lerp t=0.5 returns midpoint
var v2lh = hvec2_lerp(v2la, v2lb, F64_HALF);
assert_eq(f64_to(HVec2_x(v2lh)), 5, "v2 lerp t=0.5 .x");
assert_eq(f64_to(HVec2_y(v2lh)), 10, "v2 lerp t=0.5 .y");

# ================================================================
# Vec3 — Construction
# ================================================================
test_group("vec3 construction");

var v3z = hvec3_zero();
assert_eq(f64_to(HVec3_x(v3z)), 0, "v3 zero.x");
assert_eq(f64_to(HVec3_y(v3z)), 0, "v3 zero.y");
assert_eq(f64_to(HVec3_z(v3z)), 0, "v3 zero.z");

var v3o = hvec3_one();
assert_eq(f64_to(HVec3_x(v3o)), 1, "v3 one.x");
assert_eq(f64_to(HVec3_y(v3o)), 1, "v3 one.y");
assert_eq(f64_to(HVec3_z(v3o)), 1, "v3 one.z");

# unit vectors
assert_eq(f64_to(HVec3_x(hvec3_unit_x())), 1, "v3 unit_x.x");
assert_eq(f64_to(HVec3_y(hvec3_unit_x())), 0, "v3 unit_x.y");
assert_eq(f64_to(HVec3_z(hvec3_unit_x())), 0, "v3 unit_x.z");

assert_eq(f64_to(HVec3_x(hvec3_unit_y())), 0, "v3 unit_y.x");
assert_eq(f64_to(HVec3_y(hvec3_unit_y())), 1, "v3 unit_y.y");
assert_eq(f64_to(HVec3_z(hvec3_unit_y())), 0, "v3 unit_y.z");

assert_eq(f64_to(HVec3_x(hvec3_unit_z())), 0, "v3 unit_z.x");
assert_eq(f64_to(HVec3_y(hvec3_unit_z())), 0, "v3 unit_z.y");
assert_eq(f64_to(HVec3_z(hvec3_unit_z())), 1, "v3 unit_z.z");

# splat
var v3sp = hvec3_splat(f64_from(5));
assert_eq(f64_to(HVec3_x(v3sp)), 5, "v3 splat.x");
assert_eq(f64_to(HVec3_y(v3sp)), 5, "v3 splat.y");
assert_eq(f64_to(HVec3_z(v3sp)), 5, "v3 splat.z");

# ================================================================
# Vec3 — Arithmetic
# ================================================================
test_group("vec3 arithmetic");

var v3a = hvec3_new(f64_from(1), f64_from(2), f64_from(3));
var v3b = hvec3_new(f64_from(4), f64_from(5), f64_from(6));

# add
var v3add = hvec3_add(v3a, v3b);
assert_eq(f64_to(HVec3_x(v3add)), 5, "v3 add.x");
assert_eq(f64_to(HVec3_y(v3add)), 7, "v3 add.y");
assert_eq(f64_to(HVec3_z(v3add)), 9, "v3 add.z");

# sub
var v3sub = hvec3_sub(v3a, v3b);
assert_eq(f64_to(HVec3_x(v3sub)), (0 - 3), "v3 sub.x");
assert_eq(f64_to(HVec3_y(v3sub)), (0 - 3), "v3 sub.y");
assert_eq(f64_to(HVec3_z(v3sub)), (0 - 3), "v3 sub.z");

# mul (component-wise)
var v3mul = hvec3_mul(v3a, v3b);
assert_eq(f64_to(HVec3_x(v3mul)), 4, "v3 mul.x");
assert_eq(f64_to(HVec3_y(v3mul)), 10, "v3 mul.y");
assert_eq(f64_to(HVec3_z(v3mul)), 18, "v3 mul.z");

# scale
var v3sc = hvec3_scale(v3a, f64_from(3));
assert_eq(f64_to(HVec3_x(v3sc)), 3, "v3 scale.x");
assert_eq(f64_to(HVec3_y(v3sc)), 6, "v3 scale.y");
assert_eq(f64_to(HVec3_z(v3sc)), 9, "v3 scale.z");

# neg
var v3neg = hvec3_neg(v3a);
assert_eq(f64_to(HVec3_x(v3neg)), (0 - 1), "v3 neg.x");
assert_eq(f64_to(HVec3_y(v3neg)), (0 - 2), "v3 neg.y");
assert_eq(f64_to(HVec3_z(v3neg)), (0 - 3), "v3 neg.z");

# ================================================================
# Vec3 — Dot, Cross, Length
# ================================================================
test_group("vec3 products/norms");

# dot: (1,2,3).(4,5,6) = 4+10+18 = 32
assert_eq(f64_to(hvec3_dot(v3a, v3b)), 32, "v3 dot");

# dot with self: (1,2,3).(1,2,3) = 1+4+9 = 14
assert_eq(f64_to(hvec3_dot(v3a, v3a)), 14, "v3 dot self");

# dot orthogonal: unit_x . unit_y = 0
assert_eq(f64_to(hvec3_dot(hvec3_unit_x(), hvec3_unit_y())), 0, "v3 dot orthogonal");

# length_sq
assert_eq(f64_to(hvec3_length_sq(v3a)), 14, "v3 length_sq");

# length of (3,4,0) = 5
var v3_345 = hvec3_new(f64_from(3), f64_from(4), 0);
assert_eq(f64_to(hvec3_length(v3_345)), 5, "v3 length 3-4-0");

# cross products: x cross y = z
var cr_xy = hvec3_cross(hvec3_unit_x(), hvec3_unit_y());
assert_eq(f64_to(HVec3_x(cr_xy)), 0, "v3 x cross y .x");
assert_eq(f64_to(HVec3_y(cr_xy)), 0, "v3 x cross y .y");
assert_eq(f64_to(HVec3_z(cr_xy)), 1, "v3 x cross y .z");

# y cross z = x
var cr_yz = hvec3_cross(hvec3_unit_y(), hvec3_unit_z());
assert_eq(f64_to(HVec3_x(cr_yz)), 1, "v3 y cross z .x");
assert_eq(f64_to(HVec3_y(cr_yz)), 0, "v3 y cross z .y");
assert_eq(f64_to(HVec3_z(cr_yz)), 0, "v3 y cross z .z");

# z cross x = y
var cr_zx = hvec3_cross(hvec3_unit_z(), hvec3_unit_x());
assert_eq(f64_to(HVec3_x(cr_zx)), 0, "v3 z cross x .x");
assert_eq(f64_to(HVec3_y(cr_zx)), 1, "v3 z cross x .y");
assert_eq(f64_to(HVec3_z(cr_zx)), 0, "v3 z cross x .z");

# cross anti-commutativity: a x b = -(b x a)
var cr_ab = hvec3_cross(v3a, v3b);
var cr_ba = hvec3_cross(v3b, v3a);
assert_f64_eq(HVec3_x(cr_ab), f64_neg(HVec3_x(cr_ba)), "v3 cross anti-commute.x");
assert_f64_eq(HVec3_y(cr_ab), f64_neg(HVec3_y(cr_ba)), "v3 cross anti-commute.y");
assert_f64_eq(HVec3_z(cr_ab), f64_neg(HVec3_z(cr_ba)), "v3 cross anti-commute.z");

# cross self = zero
var cr_aa = hvec3_cross(v3a, v3a);
assert_eq(f64_to(HVec3_x(cr_aa)), 0, "v3 cross self.x");
assert_eq(f64_to(HVec3_y(cr_aa)), 0, "v3 cross self.y");
assert_eq(f64_to(HVec3_z(cr_aa)), 0, "v3 cross self.z");

# normalize
var v3norm = hvec3_normalize(v3a);
assert_f64_eq(hvec3_length(v3norm), F64_ONE, "v3 normalize length=1");

# normalize zero returns zero
var v3norm_z = hvec3_normalize(hvec3_zero());
assert_eq(f64_to(HVec3_x(v3norm_z)), 0, "v3 normalize zero.x");

# distance
var v3dist = hvec3_distance(v3a, v3b);
# dist = length((3,3,3)) = sqrt(27) = 3*sqrt(3) ~ 5.196
var v3dist_1000 = f64_to(f64_round(f64_mul(v3dist, f64_from(1000))));
assert_eq(v3dist_1000, 5196, "v3 distance");

# distance to self = 0
assert_eq(f64_to(hvec3_distance(v3a, v3a)), 0, "v3 distance self=0");

# ================================================================
# Vec3 — Lerp
# ================================================================
test_group("vec3 lerp");

var v3la = hvec3_new(0, 0, 0);
var v3lb = hvec3_new(f64_from(10), f64_from(20), f64_from(30));

# lerp t=0
var v3l0 = hvec3_lerp(v3la, v3lb, 0);
assert_eq(f64_to(HVec3_x(v3l0)), 0, "v3 lerp t=0 .x");
assert_eq(f64_to(HVec3_y(v3l0)), 0, "v3 lerp t=0 .y");
assert_eq(f64_to(HVec3_z(v3l0)), 0, "v3 lerp t=0 .z");

# lerp t=1
var v3l1 = hvec3_lerp(v3la, v3lb, F64_ONE);
assert_eq(f64_to(HVec3_x(v3l1)), 10, "v3 lerp t=1 .x");
assert_eq(f64_to(HVec3_y(v3l1)), 20, "v3 lerp t=1 .y");
assert_eq(f64_to(HVec3_z(v3l1)), 30, "v3 lerp t=1 .z");

# lerp t=0.5
var v3lh = hvec3_lerp(v3la, v3lb, F64_HALF);
assert_eq(f64_to(HVec3_x(v3lh)), 5, "v3 lerp t=0.5 .x");
assert_eq(f64_to(HVec3_y(v3lh)), 10, "v3 lerp t=0.5 .y");
assert_eq(f64_to(HVec3_z(v3lh)), 15, "v3 lerp t=0.5 .z");

# ================================================================
# Vec3 — Min, Max, Abs, Reflect
# ================================================================
test_group("vec3 min/max/abs/reflect");

var v3c = hvec3_new(f64_from(5), f64_neg(f64_from(3)), f64_from(1));
var v3d = hvec3_new(f64_from(2), f64_from(7), f64_neg(f64_from(4)));

# min
var v3min = hvec3_min(v3c, v3d);
assert_eq(f64_to(HVec3_x(v3min)), 2, "v3 min.x");
assert_eq(f64_to(HVec3_y(v3min)), (0 - 3), "v3 min.y");
assert_eq(f64_to(HVec3_z(v3min)), (0 - 4), "v3 min.z");

# max
var v3max = hvec3_max(v3c, v3d);
assert_eq(f64_to(HVec3_x(v3max)), 5, "v3 max.x");
assert_eq(f64_to(HVec3_y(v3max)), 7, "v3 max.y");
assert_eq(f64_to(HVec3_z(v3max)), 1, "v3 max.z");

# abs
var v3abs = hvec3_abs(hvec3_new(f64_neg(f64_from(3)), f64_from(4), f64_neg(f64_from(5))));
assert_eq(f64_to(HVec3_x(v3abs)), 3, "v3 abs.x");
assert_eq(f64_to(HVec3_y(v3abs)), 4, "v3 abs.y");
assert_eq(f64_to(HVec3_z(v3abs)), 5, "v3 abs.z");

# reflect: v=(1,-1,0) about n=(0,1,0) should give (1,1,0)
var v3refl_v = hvec3_new(F64_ONE, f64_neg(F64_ONE), 0);
var v3refl_n = hvec3_unit_y();
var v3refl = hvec3_reflect(v3refl_v, v3refl_n);
assert_eq(f64_to(HVec3_x(v3refl)), 1, "v3 reflect.x");
assert_eq(f64_to(HVec3_y(v3refl)), 1, "v3 reflect.y");
assert_eq(f64_to(HVec3_z(v3refl)), 0, "v3 reflect.z");

# reflect: perpendicular to normal unchanged, parallel component negated
# v=(0,1,0) about n=(0,1,0) -> (0,-1,0)
var v3refl2 = hvec3_reflect(hvec3_unit_y(), hvec3_unit_y());
assert_eq(f64_to(HVec3_y(v3refl2)), (0 - 1), "v3 reflect parallel");

# ================================================================
# Vec4 — Construction
# ================================================================
test_group("vec4 construction");

var v4z = hvec4_zero();
assert_eq(f64_to(HVec4_x(v4z)), 0, "v4 zero.x");
assert_eq(f64_to(HVec4_y(v4z)), 0, "v4 zero.y");
assert_eq(f64_to(HVec4_z(v4z)), 0, "v4 zero.z");
assert_eq(f64_to(HVec4_w(v4z)), 0, "v4 zero.w");

var v4o = hvec4_one();
assert_eq(f64_to(HVec4_x(v4o)), 1, "v4 one.x");
assert_eq(f64_to(HVec4_y(v4o)), 1, "v4 one.y");
assert_eq(f64_to(HVec4_z(v4o)), 1, "v4 one.z");
assert_eq(f64_to(HVec4_w(v4o)), 1, "v4 one.w");

# new
var v4a = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(4));
assert_eq(f64_to(HVec4_x(v4a)), 1, "v4 new.x");
assert_eq(f64_to(HVec4_y(v4a)), 2, "v4 new.y");
assert_eq(f64_to(HVec4_z(v4a)), 3, "v4 new.z");
assert_eq(f64_to(HVec4_w(v4a)), 4, "v4 new.w");

# splat
var v4sp = hvec4_splat(f64_from(9));
assert_eq(f64_to(HVec4_x(v4sp)), 9, "v4 splat.x");
assert_eq(f64_to(HVec4_w(v4sp)), 9, "v4 splat.w");

# ================================================================
# Vec4 — from_vec3 / xyz roundtrip
# ================================================================
test_group("vec4 from_vec3/xyz");

var v3src = hvec3_new(f64_from(7), f64_from(8), f64_from(9));
var v4from = hvec4_from_vec3(v3src, F64_ONE);
assert_eq(f64_to(HVec4_x(v4from)), 7, "v4 from_vec3.x");
assert_eq(f64_to(HVec4_y(v4from)), 8, "v4 from_vec3.y");
assert_eq(f64_to(HVec4_z(v4from)), 9, "v4 from_vec3.z");
assert_eq(f64_to(HVec4_w(v4from)), 1, "v4 from_vec3.w");

# roundtrip: xyz(from_vec3(v, w)) = v
var v3back = hvec4_xyz(v4from);
assert_eq(f64_to(HVec3_x(v3back)), 7, "v4 xyz roundtrip.x");
assert_eq(f64_to(HVec3_y(v3back)), 8, "v4 xyz roundtrip.y");
assert_eq(f64_to(HVec3_z(v3back)), 9, "v4 xyz roundtrip.z");

# ================================================================
# Vec4 — Arithmetic
# ================================================================
test_group("vec4 arithmetic");

var v4b = hvec4_new(f64_from(5), f64_from(6), f64_from(7), f64_from(8));

# add
var v4add = hvec4_add(v4a, v4b);
assert_eq(f64_to(HVec4_x(v4add)), 6, "v4 add.x");
assert_eq(f64_to(HVec4_y(v4add)), 8, "v4 add.y");
assert_eq(f64_to(HVec4_z(v4add)), 10, "v4 add.z");
assert_eq(f64_to(HVec4_w(v4add)), 12, "v4 add.w");

# sub
var v4sub = hvec4_sub(v4a, v4b);
assert_eq(f64_to(HVec4_x(v4sub)), (0 - 4), "v4 sub.x");
assert_eq(f64_to(HVec4_y(v4sub)), (0 - 4), "v4 sub.y");

# scale
var v4sc = hvec4_scale(v4a, f64_from(2));
assert_eq(f64_to(HVec4_x(v4sc)), 2, "v4 scale.x");
assert_eq(f64_to(HVec4_w(v4sc)), 8, "v4 scale.w");

# neg
var v4neg = hvec4_neg(v4a);
assert_eq(f64_to(HVec4_x(v4neg)), (0 - 1), "v4 neg.x");
assert_eq(f64_to(HVec4_w(v4neg)), (0 - 4), "v4 neg.w");

# ================================================================
# Vec4 — Dot, Length, Normalize
# ================================================================
test_group("vec4 dot/length/normalize");

# dot: (1,2,3,4).(5,6,7,8) = 5+12+21+32 = 70
assert_eq(f64_to(hvec4_dot(v4a, v4b)), 70, "v4 dot");

# dot self: 1+4+9+16 = 30
assert_eq(f64_to(hvec4_dot(v4a, v4a)), 30, "v4 dot self");

# length_sq
assert_eq(f64_to(hvec4_length_sq(v4a)), 30, "v4 length_sq");

# length of (1,0,0,0) = 1
assert_eq(f64_to(hvec4_length(hvec4_new(F64_ONE, 0, 0, 0))), 1, "v4 length unit");

# normalize: result should have length 1
var v4norm = hvec4_normalize(v4a);
assert_f64_eq(hvec4_length(v4norm), F64_ONE, "v4 normalize length=1");

# normalize zero returns zero
var v4norm_z = hvec4_normalize(hvec4_zero());
assert_eq(f64_to(HVec4_x(v4norm_z)), 0, "v4 normalize zero.x");

# ================================================================
# Quaternion — Identity
# ================================================================
test_group("quat identity");

var qi = hquat_identity();
assert_eq(f64_to(HQuat_x(qi)), 0, "qi.x=0");
assert_eq(f64_to(HQuat_y(qi)), 0, "qi.y=0");
assert_eq(f64_to(HQuat_z(qi)), 0, "qi.z=0");
assert_eq(f64_to(HQuat_w(qi)), 1, "qi.w=1");

# identity length = 1
assert_eq(f64_to(hquat_length(qi)), 1, "qi length=1");

# identity * identity = identity
var qii = hquat_mul(qi, qi);
assert_f64_eq(HQuat_w(qii), F64_ONE, "qi*qi.w=1");
assert_f64_eq(HQuat_x(qii), 0, "qi*qi.x=0");

# ================================================================
# Quaternion — Rotation Constructors
# ================================================================
test_group("quat rotation constructors");

# rotation_x(0) = identity
var qrx0 = hquat_from_rotation_x(0);
assert_f64_eq(HQuat_w(qrx0), F64_ONE, "rot_x(0).w=1");
assert_f64_eq(HQuat_x(qrx0), 0, "rot_x(0).x=0");

# rotation_y(0) = identity
var qry0 = hquat_from_rotation_y(0);
assert_f64_eq(HQuat_w(qry0), F64_ONE, "rot_y(0).w=1");

# rotation_z(0) = identity
var qrz0 = hquat_from_rotation_z(0);
assert_f64_eq(HQuat_w(qrz0), F64_ONE, "rot_z(0).w=1");

# rotation_x(pi) should have w~0, x~1
var qrx_pi = hquat_from_rotation_x(F64_PI);
assert_f64_eq(HQuat_w(qrx_pi), 0, "rot_x(pi).w~0");
assert_f64_eq(HQuat_x(qrx_pi), F64_ONE, "rot_x(pi).x~1");

# from_axis_angle with unit_z and pi/2 should match rotation_z(pi/2)
var qa_z90 = hquat_from_axis_angle(hvec3_unit_z(), F64_PI_2);
var qr_z90 = hquat_from_rotation_z(F64_PI_2);
assert_f64_eq(HQuat_x(qa_z90), HQuat_x(qr_z90), "axis_angle vs rot_z .x");
assert_f64_eq(HQuat_y(qa_z90), HQuat_y(qr_z90), "axis_angle vs rot_z .y");
assert_f64_eq(HQuat_z(qa_z90), HQuat_z(qr_z90), "axis_angle vs rot_z .z");
assert_f64_eq(HQuat_w(qa_z90), HQuat_w(qr_z90), "axis_angle vs rot_z .w");

# ================================================================
# Quaternion — Multiplication
# ================================================================
test_group("quat multiplication");

var qa = hquat_from_rotation_x(F64_PI_4);
var qb = hquat_from_rotation_y(F64_PI_4);

# q * identity = q
var qa_i = hquat_mul(qa, qi);
assert_f64_eq(HQuat_x(qa_i), HQuat_x(qa), "q*I.x=q.x");
assert_f64_eq(HQuat_y(qa_i), HQuat_y(qa), "q*I.y=q.y");
assert_f64_eq(HQuat_z(qa_i), HQuat_z(qa), "q*I.z=q.z");
assert_f64_eq(HQuat_w(qa_i), HQuat_w(qa), "q*I.w=q.w");

# identity * q = q
var qi_a = hquat_mul(qi, qa);
assert_f64_eq(HQuat_x(qi_a), HQuat_x(qa), "I*q.x=q.x");
assert_f64_eq(HQuat_w(qi_a), HQuat_w(qa), "I*q.w=q.w");

# mul preserves unit length
var qab = hquat_mul(qa, qb);
assert_f64_eq(hquat_length(qab), F64_ONE, "q*r length=1");

# associativity: (a*b)*c = a*(b*c)
var qc = hquat_from_rotation_z(F64_PI_4);
var qab_c = hquat_mul(hquat_mul(qa, qb), qc);
var qa_bc = hquat_mul(qa, hquat_mul(qb, qc));
assert_f64_eq(HQuat_x(qab_c), HQuat_x(qa_bc), "quat assoc.x");
assert_f64_eq(HQuat_y(qab_c), HQuat_y(qa_bc), "quat assoc.y");
assert_f64_eq(HQuat_z(qab_c), HQuat_z(qa_bc), "quat assoc.z");
assert_f64_eq(HQuat_w(qab_c), HQuat_w(qa_bc), "quat assoc.w");

# ================================================================
# Quaternion — Conjugate, Inverse
# ================================================================
test_group("quat conjugate/inverse");

# conjugate negates xyz, keeps w
var qconj = hquat_conjugate(qa);
assert_f64_eq(HQuat_x(qconj), f64_neg(HQuat_x(qa)), "conj.x=-q.x");
assert_f64_eq(HQuat_y(qconj), HQuat_y(qa), "conj.y=q.y");
assert_f64_eq(HQuat_w(qconj), HQuat_w(qa), "conj.w=q.w");

# For unit quaternions, conjugate = inverse
var qinv = hquat_inverse(qa);
assert_f64_eq(HQuat_x(qinv), HQuat_x(qconj), "unit inv=conj .x");
assert_f64_eq(HQuat_w(qinv), HQuat_w(qconj), "unit inv=conj .w");

# q * q^-1 ~ identity
var q_qinv = hquat_mul(qa, qinv);
assert_f64_eq(HQuat_w(q_qinv), F64_ONE, "q*q^-1 .w~1");
assert_f64_eq(HQuat_x(q_qinv), 0, "q*q^-1 .x~0");
assert_f64_eq(HQuat_y(q_qinv), 0, "q*q^-1 .y~0");
assert_f64_eq(HQuat_z(q_qinv), 0, "q*q^-1 .z~0");

# q^-1 * q ~ identity
var qinv_q = hquat_mul(qinv, qa);
assert_f64_eq(HQuat_w(qinv_q), F64_ONE, "q^-1*q .w~1");

# ================================================================
# Quaternion — Normalize, Dot, Length
# ================================================================
test_group("quat normalize/dot/length");

# normalize of already-normalized stays the same
var qn = hquat_normalize(qa);
assert_f64_eq(hquat_length(qn), F64_ONE, "normalize unit stays unit");

# normalize a scaled quaternion
var q_scaled = hquat_new(f64_from(2), 0, 0, f64_from(2));
var q_sn = hquat_normalize(q_scaled);
assert_f64_eq(hquat_length(q_sn), F64_ONE, "normalize scaled len=1");

# dot with self = length_sq
var qdot_self = hquat_dot(qa, qa);
var qlen_sq = hquat_length_sq(qa);
assert_f64_eq(qdot_self, qlen_sq, "dot self = len_sq");

# dot identity with identity = 1
assert_eq(f64_to(hquat_dot(qi, qi)), 1, "qi dot qi = 1");

# ================================================================
# Quaternion — Slerp
# ================================================================
test_group("quat slerp");

var qs_a = hquat_identity();
var qs_b = hquat_from_rotation_z(F64_PI_2);

# slerp t=0 = a
var qs0 = hquat_slerp(qs_a, qs_b, 0);
assert_f64_eq(HQuat_w(qs0), HQuat_w(qs_a), "slerp t=0 .w");
assert_f64_eq(HQuat_x(qs0), HQuat_x(qs_a), "slerp t=0 .x");

# slerp t=1 ~ b
var qs1 = hquat_slerp(qs_a, qs_b, F64_ONE);
assert_f64_eq(HQuat_z(qs1), HQuat_z(qs_b), "slerp t=1 .z");
assert_f64_eq(HQuat_w(qs1), HQuat_w(qs_b), "slerp t=1 .w");

# slerp t=0.5 should be a rotation of pi/4 around z
var qs_half = hquat_slerp(qs_a, qs_b, F64_HALF);
var qs_expected = hquat_from_rotation_z(F64_PI_4);
assert_f64_eq(HQuat_z(qs_half), HQuat_z(qs_expected), "slerp t=0.5 .z");
assert_f64_eq(HQuat_w(qs_half), HQuat_w(qs_expected), "slerp t=0.5 .w");

# slerp preserves unit length
assert_f64_eq(hquat_length(qs_half), F64_ONE, "slerp midpoint length=1");

# ================================================================
# Quaternion — rotate_vec3 (90-degree tests per axis)
# ================================================================
test_group("quat rotate_vec3");

# Rotate (1,0,0) by 90deg around Z -> (0,1,0)
var qrz90 = hquat_from_rotation_z(F64_PI_2);
var rot_z_x = hquat_rotate_vec3(qrz90, hvec3_unit_x());
assert_f64_eq(HVec3_x(rot_z_x), 0, "rot_z90 unit_x -> .x~0");
assert_f64_eq(HVec3_y(rot_z_x), F64_ONE, "rot_z90 unit_x -> .y~1");
assert_f64_eq(HVec3_z(rot_z_x), 0, "rot_z90 unit_x -> .z~0");

# Rotate (0,1,0) by 90deg around Z -> (-1,0,0)
var rot_z_y = hquat_rotate_vec3(qrz90, hvec3_unit_y());
assert_f64_eq(HVec3_x(rot_z_y), f64_neg(F64_ONE), "rot_z90 unit_y -> .x~-1");
assert_f64_eq(HVec3_y(rot_z_y), 0, "rot_z90 unit_y -> .y~0");

# Rotate (0,1,0) by 90deg around X -> (0,0,1)
var qrx90 = hquat_from_rotation_x(F64_PI_2);
var rot_x_y = hquat_rotate_vec3(qrx90, hvec3_unit_y());
assert_f64_eq(HVec3_x(rot_x_y), 0, "rot_x90 unit_y -> .x~0");
assert_f64_eq(HVec3_y(rot_x_y), 0, "rot_x90 unit_y -> .y~0");
assert_f64_eq(HVec3_z(rot_x_y), F64_ONE, "rot_x90 unit_y -> .z~1");

# Rotate (0,0,1) by 90deg around X -> (0,-1,0)
var rot_x_z = hquat_rotate_vec3(qrx90, hvec3_unit_z());
assert_f64_eq(HVec3_x(rot_x_z), 0, "rot_x90 unit_z -> .x~0");
assert_f64_eq(HVec3_y(rot_x_z), f64_neg(F64_ONE), "rot_x90 unit_z -> .y~-1");
assert_f64_eq(HVec3_z(rot_x_z), 0, "rot_x90 unit_z -> .z~0");

# Rotate (0,0,1) by 90deg around Y -> (1,0,0)
var qry90 = hquat_from_rotation_y(F64_PI_2);
var rot_y_z = hquat_rotate_vec3(qry90, hvec3_unit_z());
assert_f64_eq(HVec3_x(rot_y_z), F64_ONE, "rot_y90 unit_z -> .x~1");
assert_f64_eq(HVec3_y(rot_y_z), 0, "rot_y90 unit_z -> .y~0");
assert_f64_eq(HVec3_z(rot_y_z), 0, "rot_y90 unit_z -> .z~0");

# Rotate (1,0,0) by 90deg around Y -> (0,0,-1)
var rot_y_x = hquat_rotate_vec3(qry90, hvec3_unit_x());
assert_f64_eq(HVec3_x(rot_y_x), 0, "rot_y90 unit_x -> .x~0");
assert_f64_eq(HVec3_y(rot_y_x), 0, "rot_y90 unit_x -> .y~0");
assert_f64_eq(HVec3_z(rot_y_x), f64_neg(F64_ONE), "rot_y90 unit_x -> .z~-1");

# Identity rotation leaves vector unchanged
var rot_id = hquat_rotate_vec3(qi, v3a);
assert_f64_eq(HVec3_x(rot_id), HVec3_x(v3a), "identity rotate .x");
assert_f64_eq(HVec3_y(rot_id), HVec3_y(v3a), "identity rotate .y");
assert_f64_eq(HVec3_z(rot_id), HVec3_z(v3a), "identity rotate .z");

# Rotation preserves length
var v3test = hvec3_new(f64_from(3), f64_from(4), f64_from(5));
var v3rotated = hquat_rotate_vec3(qab, v3test);
assert_f64_eq(hvec3_length(v3rotated), hvec3_length(v3test), "rotation preserves length");

# ================================================================
# Mat4 — Identity
# ================================================================
test_group("mat4 identity");

var mi = m4_identity();

# diagonal = 1
assert_eq(f64_to(m4_get(mi, 0, 0)), 1, "I[0,0]=1");
assert_eq(f64_to(m4_get(mi, 1, 1)), 1, "I[1,1]=1");
assert_eq(f64_to(m4_get(mi, 2, 2)), 1, "I[2,2]=1");
assert_eq(f64_to(m4_get(mi, 3, 3)), 1, "I[3,3]=1");

# off-diagonal = 0
assert_eq(f64_to(m4_get(mi, 0, 1)), 0, "I[0,1]=0");
assert_eq(f64_to(m4_get(mi, 1, 0)), 0, "I[1,0]=0");
assert_eq(f64_to(m4_get(mi, 2, 3)), 0, "I[2,3]=0");
assert_eq(f64_to(m4_get(mi, 3, 2)), 0, "I[3,2]=0");

# I * v = v
var tv = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(4));
var mr = m4_mul_vec4(mi, tv);
assert_eq(f64_to(HVec4_x(mr)), 1, "I*v .x");
assert_eq(f64_to(HVec4_y(mr)), 2, "I*v .y");
assert_eq(f64_to(HVec4_z(mr)), 3, "I*v .z");
assert_eq(f64_to(HVec4_w(mr)), 4, "I*v .w");

# ================================================================
# Mat4 — Multiplication properties
# ================================================================
test_group("mat4 multiplication");

# I * I = I
var mii = m4_mul(mi, mi);
assert_eq(f64_to(m4_get(mii, 0, 0)), 1, "I*I[0,0]=1");
assert_eq(f64_to(m4_get(mii, 0, 1)), 0, "I*I[0,1]=0");
assert_eq(f64_to(m4_get(mii, 1, 1)), 1, "I*I[1,1]=1");
assert_eq(f64_to(m4_get(mii, 3, 3)), 1, "I*I[3,3]=1");

# Build a non-trivial matrix via SRT
var m_srt = m4_from_srt(
hvec3_new(F64_TWO, F64_TWO, F64_TWO),
hquat_identity(),
hvec3_new(f64_from(10), f64_from(20), f64_from(30))
);

# A * I = A
var m_ai = m4_mul(m_srt, mi);
assert_f64_eq(m4_get(m_ai, 0, 0), m4_get(m_srt, 0, 0), "A*I=A [0,0]");
assert_f64_eq(m4_get(m_ai, 3, 0), m4_get(m_srt, 3, 0), "A*I=A [3,0]");
assert_f64_eq(m4_get(m_ai, 3, 2), m4_get(m_srt, 3, 2), "A*I=A [3,2]");

# I * A = A
var m_ia = m4_mul(mi, m_srt);
assert_f64_eq(m4_get(m_ia, 0, 0), m4_get(m_srt, 0, 0), "I*A=A [0,0]");
assert_f64_eq(m4_get(m_ia, 3, 0), m4_get(m_srt, 3, 0), "I*A=A [3,0]");

# ================================================================
# Mat4 — get/set/copy
# ================================================================
test_group("mat4 get/set/copy");

var m_gs = m4_new();
m4_set(m_gs, 2, 1, f64_from(42));
assert_eq(f64_to(m4_get(m_gs, 2, 1)), 42, "set/get [2,1]");
assert_eq(f64_to(m4_get(m_gs, 0, 0)), 0, "new is zeroed [0,0]");

# copy is independent
var m_cp = m4_copy(m_gs);
assert_eq(f64_to(m4_get(m_cp, 2, 1)), 42, "copy preserves [2,1]");
m4_set(m_cp, 2, 1, f64_from(99));
assert_eq(f64_to(m4_get(m_gs, 2, 1)), 42, "copy is independent");

# ================================================================
# Mat4 — from_cols / col extraction
# ================================================================
test_group("mat4 from_cols/col");

var c0 = hvec4_new(F64_ONE, 0, 0, 0);
var c1 = hvec4_new(0, F64_TWO, 0, 0);
var c2 = hvec4_new(0, 0, f64_from(3), 0);
var c3 = hvec4_new(0, 0, 0, f64_from(4));
var m_fc = m4_from_cols(c0, c1, c2, c3);
assert_eq(f64_to(m4_get(m_fc, 0, 0)), 1, "from_cols [0,0]");
assert_eq(f64_to(m4_get(m_fc, 1, 1)), 2, "from_cols [1,1]");
assert_eq(f64_to(m4_get(m_fc, 2, 2)), 3, "from_cols [2,2]");
assert_eq(f64_to(m4_get(m_fc, 3, 3)), 4, "from_cols [3,3]");

# col extraction
var col0 = m4_col(m_fc, 0);
assert_eq(f64_to(HVec4_x(col0)), 1, "col(0).x");
assert_eq(f64_to(HVec4_y(col0)), 0, "col(0).y");

var col3 = m4_col(m_fc, 3);
assert_eq(f64_to(HVec4_w(col3)), 4, "col(3).w");

# ================================================================
# Mat4 — Transpose
# ================================================================
test_group("mat4 transpose");

# Build an asymmetric matrix
var m_asym = m4_new();
m4_set(m_asym, 0, 1, f64_from(5));
m4_set(m_asym, 1, 0, f64_from(7));
m4_set(m_asym, 0, 0, F64_ONE);
m4_set(m_asym, 1, 1, F64_TWO);
m4_set(m_asym, 2, 2, f64_from(3));
m4_set(m_asym, 3, 3, f64_from(4));

var m_t = m4_transpose(m_asym);
assert_eq(f64_to(m4_get(m_t, 1, 0)), 5, "transpose swaps [0,1]->[1,0]");
assert_eq(f64_to(m4_get(m_t, 0, 1)), 7, "transpose swaps [1,0]->[0,1]");
assert_eq(f64_to(m4_get(m_t, 0, 0)), 1, "transpose diag unchanged");

# transpose of transpose = original
var m_tt = m4_transpose(m_t);
assert_eq(f64_to(m4_get(m_tt, 0, 1)), 5, "transpose^2 = original [0,1]");
assert_eq(f64_to(m4_get(m_tt, 1, 0)), 7, "transpose^2 = original [1,0]");

# transpose of identity = identity
var m_it = m4_transpose(mi);
assert_eq(f64_to(m4_get(m_it, 0, 0)), 1, "transpose I [0,0]");
assert_eq(f64_to(m4_get(m_it, 0, 1)), 0, "transpose I [0,1]");
assert_eq(f64_to(m4_get(m_it, 1, 1)), 1, "transpose I [1,1]");

# ================================================================
# Mat4 — Determinant
# ================================================================
test_group("mat4 determinant");

# det(I) = 1
assert_eq(f64_to(m4_determinant(mi)), 1, "det(I)=1");

# det of a scale matrix = product of scale factors
# scale(2,3,4) -> det should be 24
var m_scale = m4_from_srt(hvec3_new(F64_TWO, f64_from(3), f64_from(4)),
hquat_identity(), hvec3_zero());
var det_scale = m4_determinant(m_scale);
assert_eq(f64_to(det_scale), 24, "det(scale 2,3,4)=24");

# det of pure translation = 1 (upper-left 3x3 is identity)
var m_trans = m4_from_srt(hvec3_one(), hquat_identity(),
hvec3_new(f64_from(5), f64_from(6), f64_from(7)));
assert_eq(f64_to(m4_determinant(m_trans)), 1, "det(translation)=1");

# det of rotation = 1 (orthogonal matrix)
var m_rot = m4_from_srt(hvec3_one(), hquat_from_rotation_z(F64_PI_4), hvec3_zero());
var det_rot = m4_determinant(m_rot);
var det_rot_1000 = f64_to(f64_round(f64_mul(det_rot, f64_from(1000))));
assert_eq(det_rot_1000, 1000, "det(rotation)~1");

# ================================================================
# Mat4 — Inverse
# ================================================================
test_group("mat4 inverse");

# inverse of identity = identity
var m_inv_i = m4_inverse(mi);
assert_eq(f64_to(m4_get(m_inv_i, 0, 0)), 1, "inv(I)[0,0]=1");
assert_eq(f64_to(m4_get(m_inv_i, 0, 1)), 0, "inv(I)[0,1]=0");
assert_eq(f64_to(m4_get(m_inv_i, 3, 3)), 1, "inv(I)[3,3]=1");

# M * M^-1 ~ I for SRT matrix
var m_test = m4_from_srt(hvec3_new(F64_TWO, f64_from(3), f64_from(4)),
hquat_from_rotation_y(F64_PI_4),
hvec3_new(f64_from(5), f64_from(6), f64_from(7)));
var m_test_inv = m4_inverse(m_test);
var m_prod = m4_mul(m_test, m_test_inv);

# Check diagonal elements ~ 1
assert_f64_eq(m4_get(m_prod, 0, 0), F64_ONE, "M*M^-1 [0,0]~1");
assert_f64_eq(m4_get(m_prod, 1, 1), F64_ONE, "M*M^-1 [1,1]~1");
assert_f64_eq(m4_get(m_prod, 2, 2), F64_ONE, "M*M^-1 [2,2]~1");
assert_f64_eq(m4_get(m_prod, 3, 3), F64_ONE, "M*M^-1 [3,3]~1");

# Check off-diagonal elements ~ 0
assert_f64_eq(m4_get(m_prod, 0, 1), 0, "M*M^-1 [0,1]~0");
assert_f64_eq(m4_get(m_prod, 1, 0), 0, "M*M^-1 [1,0]~0");
assert_f64_eq(m4_get(m_prod, 2, 0), 0, "M*M^-1 [2,0]~0");
assert_f64_eq(m4_get(m_prod, 3, 0), 0, "M*M^-1 [3,0]~0");

# M^-1 * M ~ I
var m_prod2 = m4_mul(m_test_inv, m_test);
assert_f64_eq(m4_get(m_prod2, 0, 0), F64_ONE, "M^-1*M [0,0]~1");
assert_f64_eq(m4_get(m_prod2, 1, 1), F64_ONE, "M^-1*M [1,1]~1");

# ================================================================
# Mat4 — SRT construction
# ================================================================
test_group("mat4 SRT");

# Pure translation: origin -> translation point
var srt_t = m4_from_srt(hvec3_one(), hquat_identity(),
hvec3_new(f64_from(2), f64_from(3), f64_from(4)));
var srt_p = m4_transform_point(srt_t, hvec3_zero());
assert_eq(f64_to(HVec3_x(srt_p)), 2, "srt translate.x");
assert_eq(f64_to(HVec3_y(srt_p)), 3, "srt translate.y");
assert_eq(f64_to(HVec3_z(srt_p)), 4, "srt translate.z");

# Pure scale: (1,1,1) * scale(2,3,4) = (2,3,4)
var srt_s = m4_from_srt(hvec3_new(F64_TWO, f64_from(3), f64_from(4)),
hquat_identity(), hvec3_zero());
var srt_sp = m4_transform_point(srt_s, hvec3_one());
assert_eq(f64_to(HVec3_x(srt_sp)), 2, "srt scale.x");
assert_eq(f64_to(HVec3_y(srt_sp)), 3, "srt scale.y");
assert_eq(f64_to(HVec3_z(srt_sp)), 4, "srt scale.z");

# Identity SRT leaves points unchanged
var srt_id = m4_from_srt(hvec3_one(), hquat_identity(), hvec3_zero());
var v_test = hvec3_new(f64_from(7), f64_from(8), f64_from(9));
var srt_id_p = m4_transform_point(srt_id, v_test);
assert_eq(f64_to(HVec3_x(srt_id_p)), 7, "srt identity.x");
assert_eq(f64_to(HVec3_y(srt_id_p)), 8, "srt identity.y");
assert_eq(f64_to(HVec3_z(srt_id_p)), 9, "srt identity.z");

# ================================================================
# Mat4 — transform_point vs transform_dir
# ================================================================
test_group("mat4 transform_point/dir");

var m_td = m4_from_srt(hvec3_one(), hquat_identity(),
hvec3_new(f64_from(10), f64_from(20), f64_from(30)));

# transform_point includes translation
var tp = m4_transform_point(m_td, hvec3_zero());
assert_eq(f64_to(HVec3_x(tp)), 10, "transform_point includes translation .x");
assert_eq(f64_to(HVec3_y(tp)), 20, "transform_point includes translation .y");

# transform_dir ignores translation (w=0)
var td = m4_transform_dir(m_td, hvec3_unit_x());
assert_eq(f64_to(HVec3_x(td)), 1, "transform_dir no translation .x");
assert_eq(f64_to(HVec3_y(td)), 0, "transform_dir no translation .y");
assert_eq(f64_to(HVec3_z(td)), 0, "transform_dir no translation .z");

# ================================================================
# Mat4 — Perspective
# ================================================================
test_group("mat4 perspective");

# perspective_rh: basic structural checks
var m_persp = m4_perspective_rh(F64_PI_2, F64_ONE, F64_ONE, f64_from(100));

# [2,3] should be -1 (RH perspective projects z -> -1 in clip.w)
assert_eq(f64_to(m4_get(m_persp, 2, 3)), (0 - 1), "persp [2,3]=-1");

# [3,3] should be 0 (perspective, not ortho)
assert_eq(f64_to(m4_get(m_persp, 3, 3)), 0, "persp [3,3]=0");

# [0,0] = f/aspect; with fov=pi/2 and aspect=1, f=1/tan(pi/4)=1, so [0,0]~1
var persp_00 = f64_to(f64_round(f64_mul(m4_get(m_persp, 0, 0), f64_from(1000))));
assert_eq(persp_00, 1000, "persp [0,0]~1 for fov=pi/2 aspect=1");

# perspective_reverse_z: [2,3] should be -1
var m_prz = m4_perspective_reverse_z(F64_PI_2, F64_ONE, F64_ONE);
assert_eq(f64_to(m4_get(m_prz, 2, 3)), (0 - 1), "persp_rz [2,3]=-1");

# ================================================================
# Mat4 — Ortho
# ================================================================
test_group("mat4 ortho");

var m_ortho = m4_ortho_rh(f64_neg(F64_ONE), F64_ONE,
f64_neg(F64_ONE), F64_ONE,
F64_ONE, f64_from(100));

# ortho [3,3] should be 1 (not 0 like perspective)
assert_eq(f64_to(m4_get(m_ortho, 3, 3)), 1, "ortho [3,3]=1");

# ortho [0,0] = 2/(right-left) = 2/2 = 1
assert_eq(f64_to(m4_get(m_ortho, 0, 0)), 1, "ortho [0,0]=1");

# ortho [1,1] = 2/(top-bottom) = 2/2 = 1
assert_eq(f64_to(m4_get(m_ortho, 1, 1)), 1, "ortho [1,1]=1");

# ================================================================
# Mat4 — look_at_rh
# ================================================================
test_group("mat4 look_at");

# Looking from (0,0,5) at origin, up=(0,1,0)
var m_la = m4_look_at_rh(
hvec3_new(0, 0, f64_from(5)),
hvec3_zero(),
hvec3_unit_y()
);

# Transform the eye position -> should land at origin in view space
var la_eye = m4_transform_point(m_la, hvec3_new(0, 0, f64_from(5)));
assert_f64_eq(HVec3_x(la_eye), 0, "look_at eye -> origin .x");
assert_f64_eq(HVec3_y(la_eye), 0, "look_at eye -> origin .y");
assert_f64_eq(HVec3_z(la_eye), 0, "look_at eye -> origin .z");

# Transform origin -> should be at (0,0,-5) in view space (in front of camera)
var la_origin = m4_transform_point(m_la, hvec3_zero());
assert_f64_eq(HVec3_x(la_origin), 0, "look_at origin .x~0");
assert_eq(f64_to(HVec3_z(la_origin)), (0 - 5), "look_at origin .z=-5");

# look_at should be an orthogonal matrix (det ~ 1 ignoring translation)
# The upper 3x3 determinant ~ 1 if it is a rotation
var la_det = m4_determinant(m_la);
var la_det_1000 = f64_to(f64_round(f64_mul(la_det, f64_from(1000))));
assert_eq(la_det_1000, 1000, "look_at det~1");

var r = assert_summary();
