# hisab benchmarks — comprehensive benchmark suite
# Mirrors the Rust criterion benchmarks for the Cyrius port.

include "lib/f64_util.cyr"
include "lib/error.cyr"
include "lib/vec2.cyr"
include "lib/vec3.cyr"
include "lib/vec4.cyr"
include "lib/quat.cyr"
include "lib/mat4.cyr"
include "lib/transforms.cyr"
include "lib/color.cyr"
include "lib/geo.cyr"
include "lib/calc.cyr"
include "lib/num.cyr"
include "lib/complex.cyr"

# ================================================================
# Convenience: bench(name, fn_ptr, iterations)
# ================================================================

fn bench(name, fp, n) {
    var b = bench_new(name);
    bench_run(b, fp, n);
    bench_report(b);
    return 0;
}

# ================================================================
# Pre-allocated test data (set up in main, used by bench fns)
# ================================================================

var _bv3a = 0;
var _bv3b = 0;
var _bq1 = 0;
var _bq2 = 0;
var _bm4a = 0;
var _bm4b = 0;
var _bt3a = 0;
var _bt3b = 0;
var _bray = 0;
var _bsphere = 0;
var _baabb = 0;
var _btri = 0;
var _bcx_a = 0;
var _bcx_b = 0;
var _b_srgb_val = 0;
var _b_tone_r = 0;
var _b_tone_g = 0;
var _b_tone_b = 0;
var _b_ease_t = 0;
var _b_perlin_x = 0;
var _b_perlin_y = 0;
var _b_deriv_h = 0;
var _b_deriv_x = 0;

# ================================================================
# Vec3 benchmarks
# ================================================================

fn bench_vec3_add() {
    var r = hvec3_add(_bv3a, _bv3b);
    return 0;
}

fn bench_vec3_cross() {
    var r = hvec3_cross(_bv3a, _bv3b);
    return 0;
}

fn bench_vec3_normalize() {
    var r = hvec3_normalize(_bv3a);
    return 0;
}

# ================================================================
# Quaternion benchmarks
# ================================================================

fn bench_quat_mul() {
    var r = hquat_mul(_bq1, _bq2);
    return 0;
}

fn bench_quat_slerp() {
    var r = hquat_slerp(_bq1, _bq2, F64_HALF);
    return 0;
}

fn bench_quat_rotate_vec3() {
    var r = hquat_rotate_vec3(_bq1, _bv3a);
    return 0;
}

# ================================================================
# Mat4 benchmarks
# ================================================================

fn bench_m4_mul() {
    var r = m4_mul(_bm4a, _bm4b);
    return 0;
}

fn bench_m4_inverse() {
    var r = m4_inverse(_bm4a);
    return 0;
}

fn bench_m4_transform_point() {
    var r = m4_transform_point(_bm4a, _bv3a);
    return 0;
}

# ================================================================
# Transform3D benchmarks
# ================================================================

fn bench_t3d_compose() {
    var r = t3d_compose(_bt3a, _bt3b);
    return 0;
}

# ================================================================
# Geometry / ray intersection benchmarks
# ================================================================

fn bench_ray_sphere() {
    var r = geo_ray_sphere(_bray, _bsphere);
    return 0;
}

fn bench_ray_aabb() {
    var r = geo_ray_aabb(_bray, _baabb);
    return 0;
}

fn bench_ray_triangle() {
    var r = geo_ray_triangle(_bray, _btri);
    return 0;
}

# ================================================================
# Color benchmarks
# ================================================================

fn bench_srgb_to_linear() {
    var r = srgb_to_linear(_b_srgb_val);
    return 0;
}

fn bench_tonemap_reinhard() {
    var r = tonemap_reinhard(_b_tone_r, _b_tone_g, _b_tone_b);
    return 0;
}

# ================================================================
# Calculus benchmarks
# ================================================================

fn _bench_sin_fn(x) {
    return f64_sin(x);
}

fn bench_calc_derivative() {
    var r = calc_derivative(&_bench_sin_fn, _b_deriv_x, _b_deriv_h);
    return 0;
}

fn bench_calc_integral_simpson() {
    var out = alloc(8);
    var r = calc_integral_simpson(&_bench_sin_fn, 0, F64_PI, 100, out);
    return 0;
}

# ================================================================
# Number theory benchmarks
# ================================================================

fn bench_num_gcd() {
    var r = num_gcd(1071, 462);
    return 0;
}

fn bench_num_is_prime() {
    var r = num_is_prime(1000003);
    return 0;
}

# ================================================================
# Complex number benchmarks
# ================================================================

fn bench_cx_mul() {
    var r = cx_mul(_bcx_a, _bcx_b);
    return 0;
}

# ================================================================
# Easing / noise benchmarks
# ================================================================

fn bench_ease_in_out() {
    var r = ease_in_out(_b_ease_t);
    return 0;
}

fn bench_perlin_2d() {
    var r = perlin_2d(_b_perlin_x, _b_perlin_y);
    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();

    # Set up test data
    _bv3a = hvec3_new(F64_ONE, F64_TWO, f64_from(3));
    _bv3b = hvec3_new(f64_from(4), f64_from(5), f64_from(6));

    _bq1 = hquat_from_rotation_y(F64_HALF);
    _bq2 = hquat_from_rotation_x(f64_from(1));

    _bm4a = m4_from_srt(hvec3_one(), _bq1, hvec3_new(F64_ONE, F64_TWO, f64_from(3)));
    _bm4b = m4_from_srt(hvec3_splat(F64_TWO), _bq2, hvec3_new(f64_from(4), f64_from(5), f64_from(6)));

    _bt3a = t3d_new(hvec3_new(F64_ONE, F64_TWO, f64_from(3)), _bq1, hvec3_one());
    _bt3b = t3d_new(hvec3_new(f64_from(4), f64_from(5), f64_from(6)), _bq2, hvec3_splat(F64_TWO));

    # Ray pointing along +Z from (0, 0, -10)
    var ray_origin = hvec3_new(0, 0, f64_neg(f64_from(10)));
    var ray_dir = hvec3_unit_z();
    _bray = geo_ray_new(ray_origin, ray_dir);

    # Sphere at origin, radius 1
    _bsphere = geo_sphere_new(hvec3_zero(), F64_ONE);

    # AABB from (-1,-1,-1) to (1,1,1)
    var aabb_min = hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), f64_neg(F64_ONE));
    var aabb_max = hvec3_new(F64_ONE, F64_ONE, F64_ONE);
    _baabb = geo_aabb_new(aabb_min, aabb_max);

    # Triangle in front of ray
    var tv0 = hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), 0);
    var tv1 = hvec3_new(F64_ONE, f64_neg(F64_ONE), 0);
    var tv2 = hvec3_new(0, F64_ONE, 0);
    _btri = geo_triangle_new(tv0, tv1, tv2);

    # Complex numbers
    _bcx_a = cx_new(f64_from(3), f64_from(4));
    _bcx_b = cx_new(F64_ONE, F64_TWO);

    # Color test values
    _b_srgb_val = F64_HALF;                        # 0.5
    _b_tone_r = F64_TWO;
    _b_tone_g = F64_ONE_HALF;                       # 1.5
    _b_tone_b = F64_HALF;

    # Easing / noise
    _b_ease_t = F64_HALF;
    _b_perlin_x = F64_ONE_HALF;                     # 1.5
    _b_perlin_y = 0x4002666666666666;               # 2.3

    # Derivative test values
    _b_deriv_x = F64_ONE;
    _b_deriv_h = 0x3F1A36E2EB1C432D;               # 1e-4

    println("=== hisab benchmarks ===");

    # Vec3 (1M iterations each)
    bench("vec3_add",             &bench_vec3_add,             1000000);
    bench("vec3_cross",           &bench_vec3_cross,           1000000);
    bench("vec3_normalize",       &bench_vec3_normalize,       1000000);

    # Quaternion
    bench("quat_mul",             &bench_quat_mul,             1000000);
    bench("quat_slerp",           &bench_quat_slerp,           500000);
    bench("quat_rotate_vec3",     &bench_quat_rotate_vec3,     1000000);

    # Mat4
    bench("m4_mul",               &bench_m4_mul,               500000);
    bench("m4_inverse",           &bench_m4_inverse,           200000);
    bench("m4_transform_point",   &bench_m4_transform_point,   1000000);

    # Transform3D
    bench("t3d_compose",          &bench_t3d_compose,          500000);

    # Ray intersections
    bench("ray_sphere",           &bench_ray_sphere,           1000000);
    bench("ray_aabb",             &bench_ray_aabb,             1000000);
    bench("ray_triangle",         &bench_ray_triangle,         1000000);

    # Color
    bench("srgb_to_linear",       &bench_srgb_to_linear,       1000000);
    bench("tonemap_reinhard",     &bench_tonemap_reinhard,     1000000);

    # Calculus
    bench("calc_derivative",      &bench_calc_derivative,      500000);
    bench("calc_integral_simpson", &bench_calc_integral_simpson, 100000);

    # Number theory
    bench("num_gcd",              &bench_num_gcd,              1000000);
    bench("num_is_prime",         &bench_num_is_prime,         500000);

    # Complex
    bench("cx_mul",               &bench_cx_mul,               1000000);

    # Easing / noise
    bench("ease_in_out",          &bench_ease_in_out,          1000000);
    bench("perlin_2d",            &bench_perlin_2d,            200000);

    println("=== done ===");
    return 0;
}

var r = main();
syscall(60, r);
