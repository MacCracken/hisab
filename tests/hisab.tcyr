alloc_init();

# ================================================================
# Vec2
# ================================================================
test_group("hvec2");

var a2 = hvec2_new(f64_from(3), f64_from(4));
assert_eq(f64_to(HVec2_x(a2)), 3, "new.x");
assert_eq(f64_to(HVec2_y(a2)), 4, "new.y");

var b2 = hvec2_new(f64_from(1), f64_from(2));
var c2 = hvec2_add(a2, b2);
assert_eq(f64_to(HVec2_x(c2)), 4, "add.x");
assert_eq(f64_to(HVec2_y(c2)), 6, "add.y");

var dot2 = hvec2_dot(a2, b2);
assert_eq(f64_to(dot2), 11, "dot");
assert_eq(f64_to(hvec2_length(a2)), 5, "length");

# ================================================================
# Vec3
# ================================================================
test_group("hvec3");

var a3 = hvec3_new(f64_from(1), f64_from(2), f64_from(3));
var b3 = hvec3_new(f64_from(4), f64_from(5), f64_from(6));
var c3 = hvec3_add(a3, b3);
assert_eq(f64_to(HVec3_x(c3)), 5, "add.x");
assert_eq(f64_to(HVec3_y(c3)), 7, "add.y");
assert_eq(f64_to(HVec3_z(c3)), 9, "add.z");
assert_eq(f64_to(hvec3_dot(a3, b3)), 32, "dot");

var cr = hvec3_cross(hvec3_unit_x(), hvec3_unit_y());
assert_eq(f64_to(HVec3_z(cr)), 1, "cross.z");

# ================================================================
# Vec4
# ================================================================
test_group("hvec4");

var a4 = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(4));
var b4 = hvec4_new(f64_from(5), f64_from(6), f64_from(7), f64_from(8));
assert_eq(f64_to(hvec4_dot(a4, b4)), 70, "dot");
assert_eq(f64_to(HVec3_z(hvec4_xyz(a4))), 3, "xyz.z");

# ================================================================
# Quaternion
# ================================================================
test_group("hquat");

var qi = hquat_identity();
assert_eq(f64_to(HQuat_w(qi)), 1, "identity.w");

# q * identity = q
var qr = hquat_from_rotation_z(F64_PI_2);
var qri = hquat_mul(qr, qi);
assert(f64_lt(f64_abs(f64_sub(HQuat_w(qr), HQuat_w(qri))), EPSILON_F64) == 1, "mul identity");

# Rotate (1,0,0) by 90deg around Z → approx (0,1,0)
var rotated = hquat_rotate_vec3(qr, hvec3_unit_x());
assert(f64_lt(f64_abs(HVec3_x(rotated)), f64_from(1)) == 1, "rot90.x near 0");
assert(f64_lt(f64_abs(f64_sub(HVec3_y(rotated), F64_ONE)), f64_from(1)) == 1, "rot90.y near 1");

# ================================================================
# Mat4
# ================================================================
test_group("mat4");

var mi = m4_identity();
var tv = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(1));
var mr = m4_mul_vec4(mi, tv);
assert_eq(f64_to(HVec4_x(mr)), 1, "I*v.x");
assert_eq(f64_to(HVec4_y(mr)), 2, "I*v.y");

var mii = m4_mul(mi, mi);
assert_eq(f64_to(m4_get(mii, 0, 0)), 1, "I*I[0,0]");
assert_eq(f64_to(m4_get(mii, 0, 1)), 0, "I*I[0,1]");

# SRT translate
var srt = m4_from_srt(hvec3_one(), hquat_identity(), hvec3_new(f64_from(2), f64_from(3), f64_from(4)));
var tp = m4_transform_point(srt, hvec3_zero());
assert_eq(f64_to(HVec3_x(tp)), 2, "srt.x");
assert_eq(f64_to(HVec3_y(tp)), 3, "srt.y");
assert_eq(f64_to(HVec3_z(tp)), 4, "srt.z");

# Inverse: M * M^-1 ≈ I
var inv = m4_inverse(srt);
var prod = m4_mul(srt, inv);
assert(f64_lt(f64_abs(f64_sub(m4_get(prod, 0, 0), F64_ONE)), f64_from(1)) == 1, "inv diag");

# ================================================================
# Transform3D
# ================================================================
test_group("transform3d");

var t = t3d_new(hvec3_new(f64_from(1), f64_from(2), f64_from(3)), hquat_identity(), hvec3_one());
var applied = t3d_apply(t, hvec3_zero());
assert_eq(f64_to(HVec3_x(applied)), 1, "t3d apply.x");
assert_eq(f64_to(HVec3_y(applied)), 2, "t3d apply.y");

# Compose: translate (1,0,0) then translate (0,2,0) = (1,2,0)
var ta = t3d_new(hvec3_new(F64_ONE, 0, 0), hquat_identity(), hvec3_one());
var tb = t3d_new(hvec3_new(0, F64_TWO, 0), hquat_identity(), hvec3_one());
var tc = t3d_compose(ta, tb);
var tcp = t3d_apply(tc, hvec3_zero());
assert_eq(f64_to(HVec3_x(tcp)), 1, "compose.x");
assert_eq(f64_to(HVec3_y(tcp)), 2, "compose.y");

# ================================================================
# Color
# ================================================================
test_group("color");

# sRGB round-trip: linear_to_srgb(srgb_to_linear(0.5)) ≈ 0.5
var half = F64_HALF;
var lin = srgb_to_linear(half);
var back = linear_to_srgb(lin);
assert(f64_lt(f64_abs(f64_sub(back, half)), f64_from(1)) == 1, "srgb roundtrip");

# Reinhard: 1.0 → 0.5
var tr = tonemap_reinhard(F64_ONE, F64_ONE, F64_ONE);
var trx = f64_to(f64_mul(HVec3_x(tr), f64_from(10)));
assert_eq(trx, 5, "reinhard(1)=0.5");

# Src-over with opaque src → src
var so = composite_src_over(F64_ONE, 0, 0, F64_ONE, 0, F64_ONE, 0, F64_ONE);
assert_eq(f64_to(HVec4_x(so)), 1, "src_over.r");
assert_eq(f64_to(HVec4_y(so)), 0, "src_over.g");

# ================================================================
# Interpolation
# ================================================================
test_group("interpolation");

var l = hisab_lerp(f64_from(0), f64_from(10), F64_HALF);
assert_eq(f64_to(l), 5, "lerp 0.5");

var il = hisab_inverse_lerp(f64_from(0), f64_from(10), f64_from(5));
assert_eq(f64_to(f64_mul(il, f64_from(10))), 5, "inv_lerp");

# ================================================================
# Geo — primitives and intersections
# ================================================================
test_group("geo primitives");

var ray = geo_ray_new(hvec3_zero(), hvec3_unit_z());
var sphere = geo_sphere_new(hvec3_new(0, 0, f64_from(5)), f64_from(1));
var t_hit = geo_ray_sphere(ray, sphere);
# Hit at t=4 (sphere center at z=5, radius=1, so near hit at z=4)
assert_eq(f64_to(t_hit), 4, "ray-sphere t");

var aabb = geo_aabb_new(hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), f64_neg(F64_ONE)),
hvec3_new(F64_ONE, F64_ONE, F64_ONE));
var t_aabb = geo_ray_aabb(geo_ray_new(hvec3_new(0, 0, f64_neg(f64_from(5))), hvec3_unit_z()), aabb);
assert_eq(f64_to(t_aabb), 4, "ray-aabb t");

# AABB-AABB overlap
var aabb2 = geo_aabb_new(hvec3_zero(), hvec3_new(F64_TWO, F64_TWO, F64_TWO));
assert_eq(geo_aabb_aabb(aabb, aabb2), 1, "aabb overlap");

# Sphere-sphere
var s1 = geo_sphere_new(hvec3_zero(), F64_ONE);
var s2 = geo_sphere_new(hvec3_new(F64_ONE, 0, 0), F64_ONE);
assert_eq(geo_sphere_sphere(s1, s2), 1, "sphere overlap");

# Closest point on AABB
var cp = geo_closest_point_on_aabb(aabb, hvec3_new(f64_from(5), 0, 0));
assert_eq(f64_to(HVec3_x(cp)), 1, "closest aabb.x");

# ================================================================
# Advanced geo
# ================================================================
test_group("geo advanced");

# SDF sphere: point at (3,0,0), sphere at origin r=1 → distance = 2
var sdf_p = hvec3_new(f64_from(3), 0, 0);
var sdf_c = hvec3_zero();
var sdf_d = sdf_sphere(sdf_p, sdf_c, F64_ONE);
assert_eq(f64_to(sdf_d), 2, "sdf sphere");

# SDF union: min of two distances
var d1 = f64_from(3);
var d2 = f64_from(5);
assert_eq(f64_to(sdf_union(d1, d2)), 3, "sdf union");
assert_eq(f64_to(sdf_intersection(d1, d2)), 5, "sdf intersection");

# Swept AABB: box at (-1,-1,-1)-(1,1,1), vel=(2,0,0), dt=1 → max.x = 3
var saabb = geo_aabb_new(hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), f64_neg(F64_ONE)),
hvec3_new(F64_ONE, F64_ONE, F64_ONE));
var svel = hvec3_new(F64_TWO, 0, 0);
var swept = swept_aabb(saabb, svel, F64_ONE);
assert_eq(f64_to(HVec3_x(GeoAabb_max(swept))), 3, "swept max.x");

# CGA: point embedding round-trip
var cga_p = cga_point(F64_ONE, F64_TWO, f64_from(3));
# Just check it's non-null (32 components allocated)
assert(cga_p != 0, "cga point alloc");

# ================================================================
# Calc — integration, easing
# ================================================================
test_group("calc");

# Integrate x^2 from 0 to 1 = 1/3
fn _test_x2(x) { return f64_mul(x, x); }
var int_out = alloc(8);
var rc = calc_integral_simpson(&_test_x2, 0, F64_ONE, 100, int_out);
assert_eq(rc, 0, "simpson ok");
# Result should be ~0.333... — multiply by 3 should give ~1
var int_val = load64(int_out);
var int_x3 = f64_to(f64_round(f64_mul(int_val, f64_from(3))));
assert_eq(int_x3, 1, "int x^2 = 1/3");

# Derivative of x^2 at x=3 should be 6
var dv = calc_derivative(&_test_x2, f64_from(3), f64_from(1));
# Use a large h=1 for simplicity — central diff gives (16-4)/2 = 6
assert_eq(f64_to(dv), 6, "deriv x^2 at 3");

# Easing
assert_eq(f64_to(ease_in(0)), 0, "ease_in(0)");
assert_eq(f64_to(ease_in(F64_ONE)), 1, "ease_in(1)");

# Gauss-Legendre on x^2 from 0 to 1
var gl = calc_integral_gauss5(&_test_x2, 0, F64_ONE);
var gl_x3 = f64_to(f64_round(f64_mul(gl, f64_from(3))));
assert_eq(gl_x3, 1, "gauss5 x^2");

# ================================================================
# Num — root finding, number theory, RNG
# ================================================================
test_group("num");

# GCD
assert_eq(num_gcd(12, 8), 4, "gcd(12,8)");
assert_eq(num_gcd(7, 13), 1, "gcd(7,13)");

# Modpow: 2^10 mod 1000 = 1024 mod 1000 = 24
assert_eq(num_modpow(2, 10, 1000), 24, "modpow");

# Primality
assert_eq(num_is_prime(2), 1, "2 prime");
assert_eq(num_is_prime(17), 1, "17 prime");
assert_eq(num_is_prime(15), 0, "15 not prime");
assert_eq(num_is_prime(1), 0, "1 not prime");

# Sieve
var primes = num_sieve(20);
assert_eq(vec_len(primes), 8, "primes<=20 count");
assert_eq(vec_get(primes, 0), 2, "first prime");
assert_eq(vec_get(primes, 7), 19, "8th prime");

# PCG32 RNG — deterministic
var rng = pcg32_new(42);
var r1 = pcg32_next(rng);
var r2 = pcg32_next(rng);
assert(r1 != r2, "rng produces different values");

# Kahan sum
var kdata = alloc(24);
store64(kdata, f64_from(1));
store64(kdata + 8, f64_from(2));
store64(kdata + 16, f64_from(3));
var ks = num_kahan_sum(kdata, 3);
assert_eq(f64_to(ks), 6, "kahan sum");

# Newton-Raphson: find sqrt(2) by solving x^2 - 2 = 0
fn _nr_f(x) { return f64_sub(f64_mul(x, x), F64_TWO); }
fn _nr_df(x) { return f64_mul(F64_TWO, x); }
var nr_out = alloc(8);
var nr_rc = num_newton(&_nr_f, &_nr_df, F64_ONE, EPSILON_F64, 100, nr_out);
assert_eq(nr_rc, 0, "newton ok");
var nr_val = load64(nr_out);
# sqrt(2) ≈ 1.414... — multiply by 1000 and round
var nr_1000 = f64_to(f64_round(f64_mul(nr_val, f64_from(1000))));
assert_eq(nr_1000, 1414, "newton sqrt2");

# ================================================================
# ODE solvers
# ================================================================
test_group("ode");

# DOPRI45: exponential growth dy/dt = y, y(0) = 1
# Use small dt=0.1 for single step accuracy
fn _ode_exp(t, y) { return y; }
var dp_y = alloc(8);
var dp_err = alloc(8);
var _dp_dt = f64_div(F64_ONE, f64_from(10));  # 0.1
ode_dopri45(&_ode_exp, 0, F64_ONE, _dp_dt, dp_y, dp_err);
# After dt=0.1: y should be > 1 (growth)
var dp_val = load64(dp_y);
assert(f64_gt(dp_val, F64_ONE) == 1, "dopri45 exp grows");
assert(f64_lt(dp_val, F64_TWO) == 1, "dopri45 exp bounded");

# Verlet: simple harmonic oscillator q''=-q, start q=1,v=0
# After dt=pi, q should be ≈ -1
fn _ode_sho_accel(q) { return f64_neg(q); }
var vr = ode_verlet(&_ode_sho_accel, F64_ONE, 0, F64_HALF);
# Just check it returned a valid pointer (16 bytes: q, v)
assert(vr != 0, "verlet returns result");

# Symplectic Euler: same SHO
fn _ode_dp_dq(q) { return f64_neg(q); }
fn _ode_dq_dp(p) { return p; }
var se = ode_symplectic_euler(&_ode_dq_dp, &_ode_dp_dq, F64_ONE, 0, F64_HALF);
assert(se != 0, "symplectic euler ok");

# ================================================================
# Optimization
# ================================================================
test_group("optimize");

# Gradient descent: minimize f(x) = x^2, starting at x=5
# Gradient: 2x
fn _opt_f(x_ptr) { var x = load64(x_ptr); return f64_mul(x, x); }
fn _opt_grad(x_ptr, out) { var x = load64(x_ptr); store64(out, f64_mul(F64_TWO, x)); return 0; }
var opt_x0 = alloc(8);
store64(opt_x0, f64_from(5));
var opt_out_x = alloc(8);
var opt_out_f = alloc(8);
var opt_rc = opt_gradient_descent(&_opt_f, &_opt_grad, opt_x0, 1, F64_HALF, EPSILON_F64, 1000, opt_out_x, opt_out_f);
assert_eq(opt_rc, 0, "gd converged");
# Result should be near 0
var opt_result = f64_abs(load64(opt_out_x));
assert(f64_lt(opt_result, F64_ONE) == 1, "gd x near 0");

# ================================================================
# Sparse / SVD / Eigen
# ================================================================
test_group("linalg_ext");

# Inertia sphere: I = (2/5)*m*r^2 on diagonal
var isph = inertia_sphere(f64_from(10), F64_ONE);
# I = (2/5)*10*1 = 4
assert_eq(f64_to(mat_get(isph, 0, 0)), 4, "inertia sphere diag");
assert_eq(f64_to(mat_get(isph, 0, 1)), 0, "inertia sphere off-diag");

# Eigen power: dominant eigenvalue of [[2,0],[0,1]] = 2
var epm = mat_new(2, 2);
mat_set(epm, 0, 0, f64_from(2));
mat_set(epm, 1, 1, F64_ONE);
var ep_val = alloc(8);
var ep_vec = alloc(16);
var ep_rc = eigen_power(epm, 2, 1000, ep_val, ep_vec);
assert_eq(ep_rc, 0, "eigen_power ok");
assert_eq(f64_to(f64_round(load64(ep_val))), 2, "eigen_power val=2");

# PGS: solve [[4,1],[1,3]]*x = [1,2] with no bounds
var pgs_A = mat_new(2, 2);
mat_set(pgs_A, 0, 0, f64_from(4)); mat_set(pgs_A, 0, 1, F64_ONE);
mat_set(pgs_A, 1, 0, F64_ONE); mat_set(pgs_A, 1, 1, f64_from(3));
var pgs_b = alloc(16);
store64(pgs_b, F64_ONE); store64(pgs_b + 8, F64_TWO);
var pgs_x = alloc(16);
store64(pgs_x, 0); store64(pgs_x + 8, 0);
var big = f64_from(1000000);
var pgs_lo = alloc(16); store64(pgs_lo, f64_neg(big)); store64(pgs_lo + 8, f64_neg(big));
var pgs_hi = alloc(16); store64(pgs_hi, big); store64(pgs_hi + 8, big);
solve_pgs(pgs_A, pgs_b, pgs_x, 2, pgs_lo, pgs_hi, 100);
# Solution: x ≈ [1/11, 7/11] ≈ [0.09, 0.64]
# Just check x[1] > 0 (converged to something reasonable)
assert(f64_gt(load64(pgs_x + 8), 0) == 1, "pgs x1 > 0");

# ================================================================
# Complex
# ================================================================
test_group("complex");

var ca = cx_new(f64_from(3), f64_from(4));
assert_eq(f64_to(cx_abs(ca)), 5, "abs(3+4i)");

var cb = cx_new(f64_from(1), f64_from(2));
var cc = cx_mul(ca, cb);
# (3+4i)(1+2i) = 3+6i+4i+8i² = 3+10i-8 = -5+10i
assert_eq(f64_to(HComplex_re(cc)), (0 - 5), "mul.re");
assert_eq(f64_to(HComplex_im(cc)), 10, "mul.im");

var cconj = cx_conj(ca);
assert_eq(f64_to(HComplex_im(cconj)), (0 - 4), "conj.im");

# e^(iπ) + 1 ≈ 0
var eipi = cx_exp(cx_new(0, F64_PI));
var euler = cx_add(eipi, cx_one());
assert(f64_lt(cx_abs(euler), f64_from(1)) == 1, "euler identity");

# Pauli: σx² = I
var sx = pauli_x();
var sx2 = cmat_mul(sx, sx);
var tr_sx2 = cmat_trace(sx2);
assert_eq(f64_to(HComplex_re(tr_sx2)), 2, "pauli_x^2 trace");

# Commutator [σx, σy] = 2iσz
var sy = pauli_y();
var comm = cmat_commutator(sx, sy);
# [σx,σy](0,0) should be 2i
var c00 = cmat_get(comm, 0, 0);
assert_eq(f64_to(HComplex_im(c00)), 2, "[sx,sy]_00.im");

# ================================================================
# Lie groups
# ================================================================
test_group("lie groups");

# U(1): compose = add phases
var u_a = u1_new(F64_PI_4);
var u_b = u1_new(F64_PI_4);
var u_c = u1_compose(u_a, u_b);
# pi/4 + pi/4 = pi/2
var u_phase = f64_to(f64_round(f64_mul(load64(u_c), f64_from(1000))));
var pi2_1000 = f64_to(f64_round(f64_mul(F64_PI_2, f64_from(1000))));
assert_eq(u_phase, pi2_1000, "u1 compose");

# U(1) inverse: phase + (-phase) = 0
var u_inv = u1_inv(u_a);
var u_id = u1_compose(u_a, u_inv);
assert(f64_lt(f64_abs(load64(u_id)), f64_from(1)) == 1, "u1 inv");

# SU(2): identity to quat → w=1
var su2_id = su2_identity();
var su2_q = su2_to_quat(su2_id);
assert_eq(f64_to(HQuat_w(su2_q)), 1, "su2 id.w");

# Lorentz: identity transforms (t,0,0,0) → (t,0,0,0)
var lor_id = lorentz_identity();
var tv4 = alloc(32);
store64(tv4, F64_ONE); store64(tv4 + 8, 0); store64(tv4 + 16, 0); store64(tv4 + 24, 0);
var tv4_out = lorentz_transform_4vec(lor_id, tv4);
assert_eq(f64_to(load64(tv4_out)), 1, "lorentz id t");

# Minkowski interval for timelike vector (1,0,0,0) = +1
var mink = minkowski_interval(tv4);
assert_eq(f64_to(mink), 1, "minkowski timelike");

# Gell-Mann: λ₁ trace = 0 (traceless generators)
var gm1 = gell_mann(0);
var gm1_tr = cmat_trace(gm1);
assert_eq(f64_to(HComplex_re(gm1_tr)), 0, "gm1 traceless");

# ================================================================
# Differential geometry
# ================================================================
test_group("diffgeo");

# Flat 2D Euclidean: metric = diag(1,1), all Christoffels = 0
var flat_metric_inv = alloc(32);
store64(flat_metric_inv, F64_ONE); store64(flat_metric_inv + 8, 0);
store64(flat_metric_inv + 16, 0); store64(flat_metric_inv + 24, F64_ONE);
# All metric derivatives = 0
var flat_deriv = alloc(64);
var _di = 0;
while (_di < 8) { store64(flat_deriv + _di * 8, 0); _di = _di + 1; }
var flat_chris = christoffel_symbols(flat_metric_inv, flat_deriv, 2);
assert_eq(f64_to(christoffel_get(flat_chris, 2, 0, 0, 0)), 0, "flat Gamma=0");
assert_eq(f64_to(christoffel_get(flat_chris, 2, 1, 0, 1)), 0, "flat Gamma=0 b");

# Wedge: α∧β where α=(1,0), β=(0,1) in 2D → 1-component 2-form = 1
var alpha = alloc(16);
store64(alpha, F64_ONE); store64(alpha + 8, 0);
var beta = alloc(16);
store64(beta, 0); store64(beta + 8, F64_ONE);
var w11 = wedge_1_1(alpha, beta, 2);
assert_eq(f64_to(load64(w11)), 1, "wedge e1^e2");

# ================================================================
# Symbolic
# ================================================================
test_group("symbolic");

# Build x^2 + 3 and evaluate at x=2 → 7
var sx = expr_var(str_from("x"));
var sx2 = expr_mul(sx, sx);
var s3 = expr_const(f64_from(3));
var se = expr_add(sx2, s3);
var bindings = vec_new();
vec_push(bindings, expr_bind(str_from("x"), f64_from(2)));
var sval = expr_eval(se, bindings);
assert_eq(f64_to(sval), 7, "eval x^2+3 at 2");

# Differentiate x^2 w.r.t x → should simplify to 2*x
var sd = expr_diff(se, str_from("x"));
var sd_simple = expr_simplify(sd);
# Evaluate derivative at x=2 → should be 4
var dval = expr_eval(sd_simple, bindings);
assert_eq(f64_to(dval), 4, "diff x^2+3 at 2");

# Simplify: 0 + x = x, 1 * x = x
var s_zero_plus = expr_add(expr_const(0), sx);
var s_simp = expr_simplify(s_zero_plus);
assert_eq(expr_tag(s_simp), EXPR_VAR, "0+x simplifies to var");

# To string for constant
var s_str = expr_to_str(expr_const(f64_from(42)));
assert(str_eq(s_str, str_from("42")) == 1, "to_str const");

# ================================================================
# Autodiff
# ================================================================
test_group("autodiff");

# f(x) = x^2, f'(x) = 2x at x=3: f(3)=9, f'(3)=6
var dx = dual_var(f64_from(3));
var dx2 = dual_mul(dx, dx);
assert_eq(f64_to(Dual_val(dx2)), 9, "x^2 val");
assert_eq(f64_to(Dual_deriv(dx2)), 6, "x^2 deriv");

# f(x) = sin(x), f'(x) = cos(x) at x=0: f(0)=0, f'(0)=1
var d0 = dual_var(0);
var ds = dual_sin(d0);
assert_eq(f64_to(Dual_val(ds)), 0, "sin(0)");
assert_eq(f64_to(Dual_deriv(ds)), 1, "cos(0)");

# f(x) = exp(x) at x=0: f(0)=1, f'(0)=1
var de = dual_exp(dual_var(0));
assert_eq(f64_to(Dual_val(de)), 1, "exp(0)");
assert_eq(f64_to(Dual_deriv(de)), 1, "exp'(0)");

# ================================================================
# Interval
# ================================================================
test_group("interval");

var ia = ivl_new(f64_from(1), f64_from(3));
var ib = ivl_new(f64_from(2), f64_from(4));
var ic = ivl_add(ia, ib);
assert_eq(f64_to(Interval_lo(ic)), 3, "add.lo");
assert_eq(f64_to(Interval_hi(ic)), 7, "add.hi");

assert_eq(ivl_contains(ia, f64_from(2)), 1, "contains 2");
assert_eq(ivl_contains(ia, f64_from(4)), 0, "not contains 4");
assert_eq(f64_to(ivl_width(ia)), 2, "width");

# ================================================================
# Tensor
# ================================================================
test_group("tensor");

# 2x3 tensor
var shape = alloc(16);
store64(shape, 2); store64(shape + 8, 3);
var t = tensor_new(2, shape);
tensor_set2(t, 0, 1, f64_from(42));
assert_eq(f64_to(tensor_get2(t, 0, 1)), 42, "set/get");
assert_eq(f64_to(tensor_get2(t, 0, 0)), 0, "zero init");

# Kronecker delta
assert_eq(f64_to(kronecker_delta(1, 1)), 1, "delta ii");
assert_eq(f64_to(kronecker_delta(0, 1)), 0, "delta ij");

# Minkowski metric
assert_eq(f64_to(minkowski(0, 0)), 1, "eta 00");
assert_eq(f64_to(minkowski(1, 1)), (0 - 1), "eta 11");

# Levi-Civita 3D
assert_eq(levi_civita_3(0, 1, 2), 1, "eps 012");
assert_eq(levi_civita_3(1, 0, 2), (0 - 1), "eps 102");
assert_eq(levi_civita_3(0, 0, 1), 0, "eps repeated");

var r = assert_summary();
