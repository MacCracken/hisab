# hisab test suite

include "lib/f64_util.cyr"
include "lib/error.cyr"
include "lib/vec2.cyr"
include "lib/vec3.cyr"
include "lib/vec4.cyr"
include "lib/quat.cyr"
include "lib/mat4.cyr"

alloc_init();

# ================================================================
# Vec2
# ================================================================
test_group("hvec2");

var a2 = hvec2_new(f64_from(3), f64_from(4));
assert_eq(f64_to(HVec2_x(a2)), 3, "new.x");
assert_eq(f64_to(HVec2_y(a2)), 4, "new.y");

var b2 = hvec2_new(f64_from(1), f64_from(2));
var c2 = hvec2_add(a2, b2);
assert_eq(f64_to(HVec2_x(c2)), 4, "add.x");
assert_eq(f64_to(HVec2_y(c2)), 6, "add.y");

var d2 = hvec2_sub(a2, b2);
assert_eq(f64_to(HVec2_x(d2)), 2, "sub.x");
assert_eq(f64_to(HVec2_y(d2)), 2, "sub.y");

var dot2 = hvec2_dot(a2, b2);
assert_eq(f64_to(dot2), 11, "dot");

# length of (3, 4) = 5
assert_eq(f64_to(hvec2_length(a2)), 5, "length");

# ================================================================
# Vec3
# ================================================================
test_group("hvec3");

var a3 = hvec3_new(f64_from(1), f64_from(2), f64_from(3));
var b3 = hvec3_new(f64_from(4), f64_from(5), f64_from(6));
var c3 = hvec3_add(a3, b3);
assert_eq(f64_to(HVec3_x(c3)), 5, "add.x");
assert_eq(f64_to(HVec3_y(c3)), 7, "add.y");
assert_eq(f64_to(HVec3_z(c3)), 9, "add.z");

var dot3 = hvec3_dot(a3, b3);
assert_eq(f64_to(dot3), 32, "dot");

# cross((1,0,0), (0,1,0)) = (0,0,1)
var cx = hvec3_unit_x();
var cy = hvec3_unit_y();
var cr = hvec3_cross(cx, cy);
assert_eq(f64_to(HVec3_x(cr)), 0, "cross.x");
assert_eq(f64_to(HVec3_y(cr)), 0, "cross.y");
assert_eq(f64_to(HVec3_z(cr)), 1, "cross.z");

# normalize (3,4,0) → (0.6, 0.8, 0)
var n3 = hvec3_normalize(hvec3_new(f64_from(3), f64_from(4), 0));
var nx = f64_to(f64_mul(HVec3_x(n3), f64_from(10)));
var ny = f64_to(f64_mul(HVec3_y(n3), f64_from(10)));
assert_eq(nx, 6, "norm.x*10");
assert_eq(ny, 8, "norm.y*10");

# ================================================================
# Vec4
# ================================================================
test_group("hvec4");

var a4 = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(4));
var b4 = hvec4_new(f64_from(5), f64_from(6), f64_from(7), f64_from(8));
var dot4 = hvec4_dot(a4, b4);
assert_eq(f64_to(dot4), 70, "dot");

var xyz = hvec4_xyz(a4);
assert_eq(f64_to(HVec3_z(xyz)), 3, "xyz.z");

# ================================================================
# Quaternion
# ================================================================
test_group("hquat");

var qi = hquat_identity();
assert_eq(f64_to(HQuat_w(qi)), 1, "identity.w");
assert_eq(f64_to(HQuat_x(qi)), 0, "identity.x");

# q * identity = q
var qr = hquat_from_rotation_z(F64_PI_2);
var qri = hquat_mul(qr, qi);
# w should be same
var diff_w = f64_abs(f64_sub(HQuat_w(qr), HQuat_w(qri)));
assert(f64_lt(diff_w, EPSILON_F64) == 1, "mul identity");

# Rotate (1,0,0) by 90 deg around Z → (0,1,0)
var vx = hvec3_unit_x();
var rotated = hquat_rotate_vec3(qr, vx);
var rx_err = f64_abs(HVec3_x(rotated));
var ry_err = f64_abs(f64_sub(HVec3_y(rotated), F64_ONE));
assert(f64_lt(rx_err, f64_from(1)) == 1, "rot.x near 0");
assert(f64_lt(ry_err, f64_from(1)) == 1, "rot.y near 1");

# ================================================================
# Mat4
# ================================================================
test_group("mat4");

# Identity * vec = vec
var mi = m4_identity();
var tv = hvec4_new(f64_from(1), f64_from(2), f64_from(3), f64_from(1));
var mr = m4_mul_vec4(mi, tv);
assert_eq(f64_to(HVec4_x(mr)), 1, "I*v.x");
assert_eq(f64_to(HVec4_y(mr)), 2, "I*v.y");
assert_eq(f64_to(HVec4_z(mr)), 3, "I*v.z");

# I * I = I
var mii = m4_mul(mi, mi);
assert_eq(f64_to(m4_get(mii, 0, 0)), 1, "I*I[0,0]");
assert_eq(f64_to(m4_get(mii, 1, 1)), 1, "I*I[1,1]");
assert_eq(f64_to(m4_get(mii, 0, 1)), 0, "I*I[0,1]");

# SRT: identity scale/rot + translation (2,3,4)
var srt = m4_from_srt(hvec3_one(), hquat_identity(), hvec3_new(f64_from(2), f64_from(3), f64_from(4)));
var tp = m4_transform_point(srt, hvec3_zero());
assert_eq(f64_to(HVec3_x(tp)), 2, "srt translate.x");
assert_eq(f64_to(HVec3_y(tp)), 3, "srt translate.y");
assert_eq(f64_to(HVec3_z(tp)), 4, "srt translate.z");

var r = assert_summary();
