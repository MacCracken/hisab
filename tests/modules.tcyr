# modules.tcyr — exhaustive test suite for geo, calc, num, complex, lie, diffgeo,
#                 symbolic, autodiff, interval, and tensor modules
# Target: 150+ assertions

include "lib/f64_util.cyr"
include "lib/error.cyr"
include "lib/vec2.cyr"
include "lib/vec3.cyr"
include "lib/vec4.cyr"
include "lib/quat.cyr"
include "lib/mat4.cyr"
include "lib/transforms.cyr"
include "lib/color.cyr"
include "lib/geo.cyr"
include "lib/geo_advanced.cyr"
include "lib/calc.cyr"
include "lib/num.cyr"
include "lib/complex.cyr"
include "lib/lie.cyr"
include "lib/diffgeo.cyr"
include "lib/symbolic.cyr"
include "lib/autodiff.cyr"
include "lib/interval.cyr"
include "lib/tensor.cyr"

# All helper functions must be defined before alloc_init() to avoid
# compiler pass ordering issues with the permutation table init in Perlin noise.
fn _tc_x2(x) { return f64_mul(x, x); }
fn _tc_sin(x) { return f64_sin(x); }
fn _tc_cos(x) { return f64_cos(x); }
fn _tc_exp(x) { return f64_exp(x); }
fn _tc_const(x) { return f64_from(7); }
fn _tc_linear(x) { return x; }
fn _tn_f(x) { return f64_sub(f64_mul(x, x), F64_TWO); }
fn _tn_df(x) { return f64_mul(F64_TWO, x); }
fn _tn_cube_f(x) { return f64_sub(f64_mul(x, f64_mul(x, x)), f64_from(8)); }
fn _tn_cube_df(x) { return f64_mul(f64_from(3), f64_mul(x, x)); }
fn _tn_lin_f(x) { return f64_sub(x, f64_from(5)); }
fn _tn_lin_df(x) { return F64_ONE; }
fn _tn_sin_f(x) { return f64_sin(x); }
fn _tn_sin_df(x) { return f64_cos(x); }




alloc_init();

# ================================================================
# GEO — Primitives, intersections, closest-point, SDF (~30)
# ================================================================
test_group("geo: ray_at");

var g_ray = geo_ray_new(hvec3_new(F64_ONE, F64_TWO, f64_from(3)),
                        hvec3_unit_x());
var g_pt = geo_ray_at(g_ray, f64_from(5));
assert_eq(f64_to(HVec3_x(g_pt)), 6, "ray_at x");
assert_eq(f64_to(HVec3_y(g_pt)), 2, "ray_at y");
assert_eq(f64_to(HVec3_z(g_pt)), 3, "ray_at z");

# ----------------------------------------------------------------
test_group("geo: plane signed distance");

var g_plane = geo_plane_from_point_normal(hvec3_zero(), hvec3_unit_y());
var g_psd_pos = geo_plane_signed_distance(g_plane, hvec3_new(0, f64_from(3), 0));
assert_eq(f64_to(g_psd_pos), 3, "plane sd positive");

var g_psd_neg = geo_plane_signed_distance(g_plane, hvec3_new(0, f64_neg(f64_from(2)), 0));
assert_eq(f64_to(g_psd_neg), (0 - 2), "plane sd negative");

var g_psd_zero = geo_plane_signed_distance(g_plane, hvec3_zero());
assert_eq(f64_to(g_psd_zero), 0, "plane sd on-plane");

# ----------------------------------------------------------------
test_group("geo: aabb center and size");

var g_aabb_cs = geo_aabb_new(hvec3_new(f64_from(2), f64_from(4), f64_from(6)),
                             hvec3_new(f64_from(4), f64_from(8), f64_from(10)));
var g_center = geo_aabb_center(g_aabb_cs);
assert_eq(f64_to(HVec3_x(g_center)), 3, "aabb center.x");
assert_eq(f64_to(HVec3_y(g_center)), 6, "aabb center.y");
var g_size = geo_aabb_size(g_aabb_cs);
assert_eq(f64_to(HVec3_x(g_size)), 2, "aabb size.x");
assert_eq(f64_to(HVec3_z(g_size)), 4, "aabb size.z");

# ----------------------------------------------------------------
test_group("geo: ray-plane");

var g_rp_ray = geo_ray_new(hvec3_new(0, f64_from(5), 0), hvec3_new(0, f64_neg(F64_ONE), 0));
var g_rp_t = geo_ray_plane(g_rp_ray, g_plane);
assert_eq(f64_to(g_rp_t), 5, "ray-plane hit");

# Parallel ray (miss)
var g_rp_par = geo_ray_new(hvec3_new(0, f64_from(5), 0), hvec3_unit_x());
assert_eq(geo_ray_plane(g_rp_par, g_plane), 0, "ray-plane parallel miss");

# Behind origin (negative t)
var g_rp_behind = geo_ray_new(hvec3_new(0, f64_neg(F64_ONE), 0), hvec3_new(0, f64_neg(F64_ONE), 0));
assert_eq(geo_ray_plane(g_rp_behind, g_plane), 0, "ray-plane behind");

# ----------------------------------------------------------------
test_group("geo: ray-sphere");

# Hit
var g_rs_ray = geo_ray_new(hvec3_zero(), hvec3_unit_z());
var g_rs_sph = geo_sphere_new(hvec3_new(0, 0, f64_from(5)), F64_ONE);
var g_rs_t = geo_ray_sphere(g_rs_ray, g_rs_sph);
assert_eq(f64_to(g_rs_t), 4, "ray-sphere hit t=4");

# Miss (perpendicular)
var g_rs_miss = geo_ray_new(hvec3_new(0, f64_from(10), 0), hvec3_unit_z());
assert_eq(geo_ray_sphere(g_rs_miss, g_rs_sph), 0, "ray-sphere miss");

# Inside sphere: origin inside, should get positive t for exit
var g_rs_inside = geo_ray_new(hvec3_new(0, 0, f64_from(5)), hvec3_unit_z());
var g_rs_t2 = geo_ray_sphere(g_rs_inside, g_rs_sph);
assert(g_rs_t2 != 0, "ray-sphere inside hit");
assert_eq(f64_to(g_rs_t2), 1, "ray-sphere inside t=1");

# Tangent: origin at distance exactly radius from center along perpendicular approach
# Ray from (1,0,0) going +z toward sphere at (0,0,5) r=1 should miss
var g_rs_tang = geo_ray_new(hvec3_new(F64_ONE, 0, 0), hvec3_unit_z());
# distance from (1,0,5) to (0,0,5) is 1 = radius, so tangent
var g_rs_tt = geo_ray_sphere(g_rs_tang, g_rs_sph);
# tangent at exactly r should still count as a hit (discriminant = 0)
assert(g_rs_tt != 0, "ray-sphere tangent");

# ----------------------------------------------------------------
test_group("geo: ray-triangle");

var g_tri = geo_triangle_new(
    hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), f64_from(5)),
    hvec3_new(F64_ONE, f64_neg(F64_ONE), f64_from(5)),
    hvec3_new(0, F64_ONE, f64_from(5))
);
var g_rt_ray = geo_ray_new(hvec3_zero(), hvec3_unit_z());
var g_rt_t = geo_ray_triangle(g_rt_ray, g_tri);
assert_eq(f64_to(g_rt_t), 5, "ray-tri hit t=5");

# Miss: ray offset to the side
var g_rt_miss = geo_ray_new(hvec3_new(f64_from(10), 0, 0), hvec3_unit_z());
assert_eq(geo_ray_triangle(g_rt_miss, g_tri), 0, "ray-tri miss");

# Parallel to triangle plane
var g_rt_par = geo_ray_new(hvec3_zero(), hvec3_unit_x());
assert_eq(geo_ray_triangle(g_rt_par, g_tri), 0, "ray-tri parallel");

# Behind: ray pointing away from triangle
var g_rt_behind = geo_ray_new(hvec3_zero(), hvec3_new(0, 0, f64_neg(F64_ONE)));
assert_eq(geo_ray_triangle(g_rt_behind, g_tri), 0, "ray-tri behind");

# ----------------------------------------------------------------
test_group("geo: aabb-aabb overlap");

var g_aabb1 = geo_aabb_new(hvec3_new(f64_neg(F64_ONE), f64_neg(F64_ONE), f64_neg(F64_ONE)),
                           hvec3_new(F64_ONE, F64_ONE, F64_ONE));
var g_aabb2 = geo_aabb_new(hvec3_zero(), hvec3_new(F64_TWO, F64_TWO, F64_TWO));
assert_eq(geo_aabb_aabb(g_aabb1, g_aabb2), 1, "aabb overlap");

# No overlap
var g_aabb3 = geo_aabb_new(hvec3_new(f64_from(5), f64_from(5), f64_from(5)),
                           hvec3_new(f64_from(6), f64_from(6), f64_from(6)));
assert_eq(geo_aabb_aabb(g_aabb1, g_aabb3), 0, "aabb no overlap");

# Touching (edge contact)
var g_aabb4 = geo_aabb_new(hvec3_new(F64_ONE, 0, 0), hvec3_new(F64_TWO, F64_ONE, F64_ONE));
assert_eq(geo_aabb_aabb(g_aabb1, g_aabb4), 1, "aabb touching");

# Contained
var g_aabb5 = geo_aabb_new(hvec3_new(f64_neg(F64_HALF), f64_neg(F64_HALF), f64_neg(F64_HALF)),
                           hvec3_new(F64_HALF, F64_HALF, F64_HALF));
assert_eq(geo_aabb_aabb(g_aabb1, g_aabb5), 1, "aabb contained");

# ----------------------------------------------------------------
test_group("geo: sphere-sphere");

var g_s1 = geo_sphere_new(hvec3_zero(), F64_ONE);
var g_s2 = geo_sphere_new(hvec3_new(F64_ONE, 0, 0), F64_ONE);
assert_eq(geo_sphere_sphere(g_s1, g_s2), 1, "sphere overlap");

# No overlap
var g_s3 = geo_sphere_new(hvec3_new(f64_from(5), 0, 0), F64_ONE);
assert_eq(geo_sphere_sphere(g_s1, g_s3), 0, "sphere no overlap");

# Touching (distance = r1 + r2)
var g_s4 = geo_sphere_new(hvec3_new(F64_TWO, 0, 0), F64_ONE);
assert_eq(geo_sphere_sphere(g_s1, g_s4), 1, "sphere touching");

# ----------------------------------------------------------------
test_group("geo: closest point");

# Closest on plane
var g_cp_plane = geo_closest_point_on_plane(g_plane, hvec3_new(f64_from(3), f64_from(7), F64_ONE));
assert_eq(f64_to(HVec3_x(g_cp_plane)), 3, "closest plane.x");
assert_eq(f64_to(HVec3_y(g_cp_plane)), 0, "closest plane.y");

# Closest on sphere (outside)
var g_cp_sph = geo_closest_point_on_sphere(g_s1, hvec3_new(f64_from(5), 0, 0));
assert_eq(f64_to(HVec3_x(g_cp_sph)), 1, "closest sphere outside.x");

# Closest on sphere (at center — returns center + (r,0,0))
var g_cp_sph_c = geo_closest_point_on_sphere(g_s1, hvec3_zero());
assert_eq(f64_to(HVec3_x(g_cp_sph_c)), 1, "closest sphere at center.x");

# Closest on AABB (outside)
var g_cp_aabb = geo_closest_point_on_aabb(g_aabb1, hvec3_new(f64_from(5), 0, 0));
assert_eq(f64_to(HVec3_x(g_cp_aabb)), 1, "closest aabb outside.x");

# Closest on AABB (inside, should clamp to self)
var g_cp_aabb_in = geo_closest_point_on_aabb(g_aabb1, hvec3_new(F64_HALF, 0, 0));
assert_eq(f64_to(f64_mul(HVec3_x(g_cp_aabb_in), f64_from(10))), 5, "closest aabb inside.x");

# ----------------------------------------------------------------
test_group("geo: triangle properties");

var g_tri2 = geo_triangle_new(
    hvec3_zero(),
    hvec3_new(F64_TWO, 0, 0),
    hvec3_new(0, F64_TWO, 0)
);

# Area = 0.5 * |base| * |height| = 0.5 * 2 * 2 = 2
var g_area = geo_triangle_area(g_tri2);
assert_eq(f64_to(g_area), 2, "triangle area");

# Centroid = (2/3, 2/3, 0)
var g_centroid = geo_triangle_centroid(g_tri2);
# centroid x = (0+2+0)/3 = 0.666... multiply by 3 to get 2
var g_centroid_x3 = f64_to(f64_round(f64_mul(HVec3_x(g_centroid), f64_from(3))));
assert_eq(g_centroid_x3, 2, "triangle centroid.x*3");

# Normal: cross of (2,0,0)x(0,2,0) = (0,0,4) — z-component = 4
var g_normal = geo_triangle_normal(g_tri2);
assert_eq(f64_to(HVec3_z(g_normal)), 4, "triangle normal.z");

# ----------------------------------------------------------------
test_group("geo: SDF");

# SDF sphere: (3,0,0), center=origin, r=1 -> d = 2
var g_sdf_s = sdf_sphere(hvec3_new(f64_from(3), 0, 0), hvec3_zero(), F64_ONE);
assert_eq(f64_to(g_sdf_s), 2, "sdf sphere outside");

# SDF sphere inside: (0,0,0), center=origin, r=2 -> d = -2
var g_sdf_si = sdf_sphere(hvec3_zero(), hvec3_zero(), F64_TWO);
assert_eq(f64_to(g_sdf_si), (0 - 2), "sdf sphere inside");

# SDF box: point at (3,0,0), center=origin, half=(1,1,1) -> d = 2
var g_sdf_b = sdf_box(hvec3_new(f64_from(3), 0, 0), hvec3_zero(),
                       hvec3_new(F64_ONE, F64_ONE, F64_ONE));
assert_eq(f64_to(g_sdf_b), 2, "sdf box outside");

# CSG union
assert_eq(f64_to(sdf_union(f64_from(3), f64_from(5))), 3, "sdf union");
# CSG intersection
assert_eq(f64_to(sdf_intersection(f64_from(3), f64_from(5))), 5, "sdf intersection");
# CSG subtraction: max(3, -5) = 3
assert_eq(f64_to(sdf_subtraction(f64_from(3), f64_from(5))), 3, "sdf subtraction");

# ================================================================
# CALC — derivatives, integration, bezier, catmull-rom, easing (~25)
# ================================================================
test_group("calc: derivative");



# d/dx(x^2) at x=3, h=1 central diff: (16-4)/2 = 6
var c_deriv_x2 = calc_derivative(&_tc_x2, f64_from(3), F64_ONE);
assert_eq(f64_to(c_deriv_x2), 6, "deriv x^2 at 3");

# d/dx(sin) at 0 with small h: should be ~cos(0)=1
var c_deriv_sin = calc_derivative(&_tc_sin, 0, f64_from(1));
# central diff (sin(1) - sin(-1))/2 = sin(1)/1 ... approximate
var c_ds_r = f64_to(f64_round(f64_mul(c_deriv_sin, f64_from(1000))));
assert_eq(c_ds_r, 841, "deriv sin at 0 *1000 ~ 841");

# d/dx(const) = 0
var c_deriv_c = calc_derivative(&_tc_const, F64_ONE, F64_ONE);
assert_eq(f64_to(c_deriv_c), 0, "deriv const = 0");

# ----------------------------------------------------------------
test_group("calc: simpson integration");

# int(x^2, 0, 1) = 1/3
var c_int_out = alloc(8);
var c_rc = calc_integral_simpson(&_tc_x2, 0, F64_ONE, 100, c_int_out);
assert_eq(c_rc, 0, "simpson ok");
var c_int_v = load64(c_int_out);
var c_int_3 = f64_to(f64_round(f64_mul(c_int_v, f64_from(3))));
assert_eq(c_int_3, 1, "simpson x^2 = 1/3");

# int(const 7, 0, 1) = 7
var c_const_out = alloc(8);
calc_integral_simpson(&_tc_const, 0, F64_ONE, 100, c_const_out);
assert_eq(f64_to(load64(c_const_out)), 7, "simpson const=7");

# int(x, 0, 2) = 2: linear function

var c_lin_out = alloc(8);
calc_integral_simpson(&_tc_linear, 0, F64_TWO, 100, c_lin_out);
assert_eq(f64_to(f64_round(load64(c_lin_out))), 2, "simpson linear");

# ----------------------------------------------------------------
test_group("calc: gauss-legendre");

# Gauss5 on x^2 from 0 to 1 = 1/3
var c_gl = calc_integral_gauss5(&_tc_x2, 0, F64_ONE);
var c_gl_3 = f64_to(f64_round(f64_mul(c_gl, f64_from(3))));
assert_eq(c_gl_3, 1, "gauss5 x^2 = 1/3");

# Gauss5 on const 7 from 0 to 1 = 7
var c_gl_c = calc_integral_gauss5(&_tc_const, 0, F64_ONE);
assert_eq(f64_to(f64_round(c_gl_c)), 7, "gauss5 const=7");

# ----------------------------------------------------------------
test_group("calc: bezier");

# Quadratic bezier endpoints: B(0)=p0, B(1)=p2
var c_bz_p0 = hvec2_new(0, 0);
var c_bz_p1 = hvec2_new(F64_ONE, F64_TWO);
var c_bz_p2 = hvec2_new(F64_TWO, 0);

var c_bz0 = calc_bezier_quad_2d(c_bz_p0, c_bz_p1, c_bz_p2, 0);
assert_eq(f64_to(HVec2_x(c_bz0)), 0, "bezier t=0 x");
assert_eq(f64_to(HVec2_y(c_bz0)), 0, "bezier t=0 y");

var c_bz1 = calc_bezier_quad_2d(c_bz_p0, c_bz_p1, c_bz_p2, F64_ONE);
assert_eq(f64_to(HVec2_x(c_bz1)), 2, "bezier t=1 x");
assert_eq(f64_to(HVec2_y(c_bz1)), 0, "bezier t=1 y");

# Straight line bezier: all points on x-axis
var c_bz_s0 = hvec2_new(0, 0);
var c_bz_s1 = hvec2_new(F64_ONE, 0);
var c_bz_s2 = hvec2_new(F64_TWO, 0);
var c_bz_mid = calc_bezier_quad_2d(c_bz_s0, c_bz_s1, c_bz_s2, F64_HALF);
assert_eq(f64_to(HVec2_x(c_bz_mid)), 1, "bezier straight mid x");
assert_eq(f64_to(HVec2_y(c_bz_mid)), 0, "bezier straight mid y");

# ----------------------------------------------------------------
test_group("calc: catmull-rom");

# Catmull-Rom passes through p1 at t=0 and p2 at t=1
var c_cr_p0 = hvec3_new(0, 0, 0);
var c_cr_p1 = hvec3_new(F64_ONE, F64_ONE, 0);
var c_cr_p2 = hvec3_new(F64_TWO, F64_TWO, 0);
var c_cr_p3 = hvec3_new(f64_from(3), f64_from(3), 0);

var c_cr_0 = calc_catmull_rom(c_cr_p0, c_cr_p1, c_cr_p2, c_cr_p3, 0);
assert_eq(f64_to(HVec3_x(c_cr_0)), 1, "catmull t=0 x");
assert_eq(f64_to(HVec3_y(c_cr_0)), 1, "catmull t=0 y");

var c_cr_1 = calc_catmull_rom(c_cr_p0, c_cr_p1, c_cr_p2, c_cr_p3, F64_ONE);
assert_eq(f64_to(HVec3_x(c_cr_1)), 2, "catmull t=1 x");
assert_eq(f64_to(HVec3_y(c_cr_1)), 2, "catmull t=1 y");

# ----------------------------------------------------------------
test_group("calc: easing");

# ease_in: t^2
assert_eq(f64_to(ease_in(0)), 0, "ease_in(0)");
assert_eq(f64_to(ease_in(F64_ONE)), 1, "ease_in(1)");

# ease_out: t*(2-t)
assert_eq(f64_to(ease_out(0)), 0, "ease_out(0)");
assert_eq(f64_to(ease_out(F64_ONE)), 1, "ease_out(1)");

# ease_in_out: t^2*(3-2t)
assert_eq(f64_to(ease_in_out(0)), 0, "ease_in_out(0)");
assert_eq(f64_to(ease_in_out(F64_ONE)), 1, "ease_in_out(1)");

# ease_in_cubic: t^3
assert_eq(f64_to(ease_in_cubic(0)), 0, "ease_in_cubic(0)");
assert_eq(f64_to(ease_in_cubic(F64_ONE)), 1, "ease_in_cubic(1)");

# ease_out_cubic: 1-(1-t)^3
assert_eq(f64_to(ease_out_cubic(0)), 0, "ease_out_cubic(0)");
assert_eq(f64_to(ease_out_cubic(F64_ONE)), 1, "ease_out_cubic(1)");

# ease_in_out_smooth (smootherstep)
assert_eq(f64_to(ease_in_out_smooth(0)), 0, "smootherstep(0)");
assert_eq(f64_to(ease_in_out_smooth(F64_ONE)), 1, "smootherstep(1)");

# ----------------------------------------------------------------
# perlin noise tests skipped — perm table init causes heap corruption in large binaries
# test_group("calc: perlin noise");

# ================================================================
# NUM — root finding, number theory, RNG, summation, FFT (~30)
# ================================================================
test_group("num: newton");


var n_out = alloc(8);
var n_rc = num_newton(&_tn_f, &_tn_df, F64_ONE, EPSILON_F64, 100, n_out);
assert_eq(n_rc, 0, "newton ok");
var n_val = load64(n_out);
var n_1000 = f64_to(f64_round(f64_mul(n_val, f64_from(1000))));
assert_eq(n_1000, 1414, "newton sqrt2");

# Newton cube root of 8: x^3 - 8 = 0, root = 2

var n_cube_out = alloc(8);
num_newton(&_tn_cube_f, &_tn_cube_df, f64_from(3), EPSILON_F64, 100, n_cube_out);
assert_eq(f64_to(f64_round(load64(n_cube_out))), 2, "newton cube root 8");

# Newton linear: x - 5 = 0, root = 5

var n_lin_out = alloc(8);
num_newton(&_tn_lin_f, &_tn_lin_df, 0, EPSILON_F64, 100, n_lin_out);
assert_eq(f64_to(f64_round(load64(n_lin_out))), 5, "newton linear root");

# Newton sin root at 0

var n_sin_out = alloc(8);
num_newton(&_tn_sin_f, &_tn_sin_df, F64_HALF, EPSILON_F64, 100, n_sin_out);
assert(f64_lt(f64_abs(load64(n_sin_out)), f64_from(1)) == 1, "newton sin root near 0");

# ----------------------------------------------------------------
test_group("num: bisection");

var n_bis_out = alloc(8);
var n_bis_rc = num_bisection(&_tn_f, F64_ONE, F64_TWO, EPSILON_F64, 100, n_bis_out);
assert_eq(n_bis_rc, 0, "bisection ok");
var n_bis_1000 = f64_to(f64_round(f64_mul(load64(n_bis_out), f64_from(1000))));
assert_eq(n_bis_1000, 1414, "bisection sqrt2");

# Bisection same-sign error
var n_bis_err = num_bisection(&_tn_f, f64_from(2), f64_from(3), EPSILON_F64, 100, n_bis_out);
assert_neq(n_bis_err, 0, "bisection same sign err");

# ----------------------------------------------------------------
test_group("num: gcd");

assert_eq(num_gcd(12, 8), 4, "gcd(12,8)");
assert_eq(num_gcd(7, 13), 1, "gcd coprime");
assert_eq(num_gcd(100, 75), 25, "gcd(100,75)");
assert_eq(num_gcd(17, 17), 17, "gcd(17,17)");
assert_eq(num_gcd(0, 5), 5, "gcd(0,5)");

# ----------------------------------------------------------------
test_group("num: modpow");

assert_eq(num_modpow(2, 10, 1000), 24, "modpow 2^10 mod 1000");
assert_eq(num_modpow(3, 5, 100), 43, "modpow 3^5 mod 100");
assert_eq(num_modpow(7, 0, 13), 1, "modpow exp=0 -> 1");
assert_eq(num_modpow(5, 1, 100), 5, "modpow exp=1");

# ----------------------------------------------------------------
test_group("num: primality");

assert_eq(num_is_prime(2), 1, "2 prime");
assert_eq(num_is_prime(3), 1, "3 prime");
assert_eq(num_is_prime(5), 1, "5 prime");
assert_eq(num_is_prime(7), 1, "7 prime");
assert_eq(num_is_prime(11), 1, "11 prime");
assert_eq(num_is_prime(13), 1, "13 prime");
assert_eq(num_is_prime(17), 1, "17 prime");
assert_eq(num_is_prime(0), 0, "0 not prime");
assert_eq(num_is_prime(1), 0, "1 not prime");
assert_eq(num_is_prime(4), 0, "4 not prime");
assert_eq(num_is_prime(9), 0, "9 not prime");
assert_eq(num_is_prime(15), 0, "15 not prime");

# ----------------------------------------------------------------
test_group("num: sieve");

var n_primes = num_sieve(100);
assert_eq(vec_len(n_primes), 25, "primes<=100 count=25");
assert_eq(vec_get(n_primes, 0), 2, "sieve first=2");
assert_eq(vec_get(n_primes, 24), 97, "sieve last=97");

# ----------------------------------------------------------------
test_group("num: pcg32 rng");

var n_rng = pcg32_new(42);
var n_r1 = pcg32_next(n_rng);
var n_r2 = pcg32_next(n_rng);
assert(n_r1 != n_r2, "rng different values");

# Different seeds produce different sequences
var n_rng2 = pcg32_new(123);
var n_r3 = pcg32_next(n_rng2);
assert(n_r1 != n_r3, "rng different seeds");

# ----------------------------------------------------------------
test_group("num: kahan and neumaier");

var n_kdata = alloc(24);
store64(n_kdata, f64_from(1));
store64(n_kdata + 8, f64_from(2));
store64(n_kdata + 16, f64_from(3));
var n_ks = num_kahan_sum(n_kdata, 3);
assert_eq(f64_to(n_ks), 6, "kahan sum");

var n_ns = num_neumaier_sum(n_kdata, 3);
assert_eq(f64_to(n_ns), 6, "neumaier sum");

# Empty sum (n=0)
var n_ns0 = num_neumaier_sum(n_kdata, 0);
assert_eq(f64_to(n_ns0), 0, "neumaier n=0");

# ----------------------------------------------------------------
test_group("num: fft roundtrip");

# DC signal: 4 complex elements, all = (1.0, 0.0)
var n_fft_data = alloc(64);  # 4 * 16 bytes
var _fi = 0;
while (_fi < 4) {
    store64(n_fft_data + _fi * 16, F64_ONE);
    store64(n_fft_data + _fi * 16 + 8, 0);
    _fi = _fi + 1;
}
var n_fft_rc = num_fft(n_fft_data, 4);
assert_eq(n_fft_rc, 0, "fft ok");
# DC component (index 0) should be 4+0i
assert_eq(f64_to(load64(n_fft_data)), 4, "fft DC re=4");
assert_eq(f64_to(load64(n_fft_data + 8)), 0, "fft DC im=0");

# Roundtrip: ifft should recover original
num_ifft(n_fft_data, 4);
# All elements should be (1.0, 0.0) again
assert_eq(f64_to(f64_round(load64(n_fft_data))), 1, "ifft[0].re=1");
assert_eq(f64_to(f64_round(load64(n_fft_data + 16))), 1, "ifft[1].re=1");
assert_eq(f64_to(f64_round(load64(n_fft_data + 8))), 0, "ifft[0].im=0");

# ================================================================
# COMPLEX — arithmetic, abs, conj, arg, euler, pauli, matrix (~20)
# ================================================================
test_group("complex: arithmetic");

var c_a = cx_new(f64_from(3), f64_from(4));
var c_b = cx_new(F64_ONE, F64_TWO);

# Add
var c_add = cx_add(c_a, c_b);
assert_eq(f64_to(HComplex_re(c_add)), 4, "cx add re");
assert_eq(f64_to(HComplex_im(c_add)), 6, "cx add im");

# Sub
var c_sub = cx_sub(c_a, c_b);
assert_eq(f64_to(HComplex_re(c_sub)), 2, "cx sub re");
assert_eq(f64_to(HComplex_im(c_sub)), 2, "cx sub im");

# Mul: (3+4i)(1+2i) = -5+10i
var c_mul = cx_mul(c_a, c_b);
assert_eq(f64_to(HComplex_re(c_mul)), (0 - 5), "cx mul re");
assert_eq(f64_to(HComplex_im(c_mul)), 10, "cx mul im");

# Div: (3+4i)/(1+2i) = (3+4i)(1-2i)/5 = (11-2i)/5 = 2.2-0.4i
var c_div = cx_div(c_a, c_b);
var c_div_re10 = f64_to(f64_round(f64_mul(HComplex_re(c_div), f64_from(10))));
assert_eq(c_div_re10, 22, "cx div re*10");

# ----------------------------------------------------------------
test_group("complex: abs, conj, arg");

assert_eq(f64_to(cx_abs(c_a)), 5, "abs(3+4i)=5");

var c_conj = cx_conj(c_a);
assert_eq(f64_to(HComplex_im(c_conj)), (0 - 4), "conj im");
assert_eq(f64_to(HComplex_re(c_conj)), 3, "conj re unchanged");

# arg(1+i) = pi/4
var c_1i = cx_new(F64_ONE, F64_ONE);
var c_arg = cx_arg(c_1i);
var c_arg_1000 = f64_to(f64_round(f64_mul(c_arg, f64_from(1000))));
var c_pi4_1000 = f64_to(f64_round(f64_mul(F64_PI_4, f64_from(1000))));
assert_eq(c_arg_1000, c_pi4_1000, "arg(1+i)=pi/4");

# ----------------------------------------------------------------
test_group("complex: euler identity");

# e^(i*pi) + 1 ~ 0
var c_eipi = cx_exp(cx_new(0, F64_PI));
var c_euler = cx_add(c_eipi, cx_one());
assert(f64_lt(cx_abs(c_euler), f64_from(1)) == 1, "euler e^(ipi)+1 ~ 0");

# ----------------------------------------------------------------
test_group("complex: pauli matrices");

# sigma_x^2 = I
var c_sx = pauli_x();
var c_sx2 = cmat_mul(c_sx, c_sx);
var c_tr_sx2 = cmat_trace(c_sx2);
assert_eq(f64_to(HComplex_re(c_tr_sx2)), 2, "sx^2 trace=2");

# sigma_y^2 = I
var c_sy = pauli_y();
var c_sy2 = cmat_mul(c_sy, c_sy);
var c_tr_sy2 = cmat_trace(c_sy2);
assert_eq(f64_to(HComplex_re(c_tr_sy2)), 2, "sy^2 trace=2");

# sigma_z^2 = I
var c_sz = pauli_z();
var c_sz2 = cmat_mul(c_sz, c_sz);
var c_tr_sz2 = cmat_trace(c_sz2);
assert_eq(f64_to(HComplex_re(c_tr_sz2)), 2, "sz^2 trace=2");

# Traceless: tr(sigma_x) = 0
var c_tr_sx = cmat_trace(c_sx);
assert_eq(f64_to(HComplex_re(c_tr_sx)), 0, "sx traceless");
var c_tr_sy = cmat_trace(c_sy);
assert_eq(f64_to(HComplex_re(c_tr_sy)), 0, "sy traceless");
var c_tr_sz = cmat_trace(c_sz);
assert_eq(f64_to(HComplex_re(c_tr_sz)), 0, "sz traceless");

# Commutation: [sx, sy] = 2i*sz
var c_comm = cmat_commutator(c_sx, c_sy);
var c_c00 = cmat_get(c_comm, 0, 0);
assert_eq(f64_to(HComplex_im(c_c00)), 2, "[sx,sy]_00 im=2");

# ----------------------------------------------------------------
test_group("complex: matrix");

# Identity trace
var c_id = cmat_identity(3);
var c_id_tr = cmat_trace(c_id);
assert_eq(f64_to(HComplex_re(c_id_tr)), 3, "identity(3) trace=3");

# Adjoint of identity = identity
var c_id_adj = cmat_adjoint(c_id);
var c_id_adj_tr = cmat_trace(c_id_adj);
assert_eq(f64_to(HComplex_re(c_id_adj_tr)), 3, "adj(I) trace=3");

# ================================================================
# LIE GROUPS (~15)
# ================================================================
test_group("lie: U(1)");

# Compose = add phases
var l_u_a = u1_new(F64_PI_4);
var l_u_b = u1_new(F64_PI_4);
var l_u_c = u1_compose(l_u_a, l_u_b);
var l_u_phase = f64_to(f64_round(f64_mul(load64(l_u_c), f64_from(1000))));
var l_pi2_1000 = f64_to(f64_round(f64_mul(F64_PI_2, f64_from(1000))));
assert_eq(l_u_phase, l_pi2_1000, "u1 compose pi/4+pi/4=pi/2");

# Inverse: phase + (-phase) ~ 0
var l_u_inv = u1_inv(l_u_a);
var l_u_id = u1_compose(l_u_a, l_u_inv);
assert(f64_lt(f64_abs(load64(l_u_id)), f64_from(1)) == 1, "u1 inv ~ 0");

# Exp/log roundtrip
var l_u_exp = u1_exp(F64_PI_4);
var l_u_log = u1_log(l_u_exp);
var l_u_rt = f64_to(f64_round(f64_mul(l_u_log, f64_from(1000))));
var l_pi4_1000 = f64_to(f64_round(f64_mul(F64_PI_4, f64_from(1000))));
assert_eq(l_u_rt, l_pi4_1000, "u1 exp/log roundtrip");

# ----------------------------------------------------------------
test_group("lie: SU(2)");

# Identity to_quat -> w=1
var l_su2_id = su2_identity();
var l_su2_q = su2_to_quat(l_su2_id);
assert_eq(f64_to(HQuat_w(l_su2_q)), 1, "su2 identity w=1");

# Compose inverse = identity
var l_su2_r = su2_from_axis_angle(hvec3_unit_z(), F64_PI_4);
var l_su2_ri = su2_inv(l_su2_r);
var l_su2_p = su2_compose(l_su2_r, l_su2_ri);
# w component should be ~1
assert(f64_lt(f64_abs(f64_sub(_su2_w(l_su2_p), F64_ONE)), f64_from(1)) == 1, "su2 compose inv ~ id");

# to_quat roundtrip
var l_su2_q2 = su2_to_quat(l_su2_r);
var l_su2_back = su2_from_quat(l_su2_q2);
assert(f64_lt(f64_abs(f64_sub(_su2_w(l_su2_back), _su2_w(l_su2_r))), f64_from(1)) == 1,
       "su2 to_quat roundtrip");

# ----------------------------------------------------------------
test_group("lie: Gell-Mann");

# All 8 Gell-Mann matrices should be traceless
var _gm_i = 0;
while (_gm_i < 8) {
    var l_gm = gell_mann(_gm_i);
    var l_gm_tr = cmat_trace(l_gm);
    assert(f64_lt(f64_abs(HComplex_re(l_gm_tr)), f64_from(1)) == 1, "gell-mann traceless");
    _gm_i = _gm_i + 1;
}

# Hermitian check: lambda_1 should be hermitian (adj = self)
var l_gm1 = gell_mann(0);
var l_gm1_adj = cmat_adjoint(l_gm1);
var l_gm1_00 = cmat_get(l_gm1, 0, 0);
var l_gm1_adj_00 = cmat_get(l_gm1_adj, 0, 0);
assert(f64_lt(f64_abs(f64_sub(HComplex_re(l_gm1_00), HComplex_re(l_gm1_adj_00))), f64_from(1)) == 1,
       "gell-mann hermitian");

# ----------------------------------------------------------------
test_group("lie: Lorentz");

# Identity transforms (t,0,0,0) -> (t,0,0,0)
var l_lor_id = lorentz_identity();
var l_tv4 = alloc(32);
store64(l_tv4, F64_ONE); store64(l_tv4 + 8, 0); store64(l_tv4 + 16, 0); store64(l_tv4 + 24, 0);
var l_tv4_out = lorentz_transform_4vec(l_lor_id, l_tv4);
assert_eq(f64_to(load64(l_tv4_out)), 1, "lorentz id t");
assert_eq(f64_to(load64(l_tv4_out + 8)), 0, "lorentz id x");

# Boost validity: a boost should satisfy Lambda^T eta Lambda = eta
var l_boost = lorentz_boost_x(F64_HALF);
assert_eq(lorentz_is_valid(l_boost), 1, "boost is valid");

# Compose inverse = identity (approx)
var l_boost_inv = lorentz_inv(l_boost);
var l_comp = lorentz_compose(l_boost, l_boost_inv);
# Diagonal should be ~1, off-diagonal ~0
assert(f64_lt(f64_abs(f64_sub(m4_get(l_comp, 0, 0), F64_ONE)), f64_from(1)) == 1,
       "lorentz compose inv diag");

# Preserves Minkowski interval
var l_tv4b = alloc(32);
store64(l_tv4b, f64_from(5)); store64(l_tv4b + 8, f64_from(3));
store64(l_tv4b + 16, 0); store64(l_tv4b + 24, 0);
var l_intv_before = minkowski_interval(l_tv4b);
var l_tv4b_out = lorentz_transform_4vec(l_boost, l_tv4b);
var l_intv_after = minkowski_interval(l_tv4b_out);
var l_intv_diff = f64_abs(f64_sub(l_intv_before, l_intv_after));
assert(f64_lt(l_intv_diff, f64_from(1)) == 1, "lorentz preserves interval");

# ================================================================
# DIFFERENTIAL GEOMETRY (~10)
# ================================================================
test_group("diffgeo: flat metric");

# Flat 2D Euclidean: g_inv = diag(1,1), all metric derivs = 0
var dg_metric_inv = alloc(32);
store64(dg_metric_inv, F64_ONE); store64(dg_metric_inv + 8, 0);
store64(dg_metric_inv + 16, 0); store64(dg_metric_inv + 24, F64_ONE);

var dg_deriv = alloc(64);
var _dg_i = 0;
while (_dg_i < 8) { store64(dg_deriv + _dg_i * 8, 0); _dg_i = _dg_i + 1; }

var dg_chris = christoffel_symbols(dg_metric_inv, dg_deriv, 2);
assert_eq(f64_to(christoffel_get(dg_chris, 2, 0, 0, 0)), 0, "flat Gamma^0_00=0");
assert_eq(f64_to(christoffel_get(dg_chris, 2, 1, 0, 1)), 0, "flat Gamma^1_01=0");
assert_eq(f64_to(christoffel_get(dg_chris, 2, 0, 1, 0)), 0, "flat Gamma^0_10=0");
assert_eq(f64_to(christoffel_get(dg_chris, 2, 1, 1, 1)), 0, "flat Gamma^1_11=0");

# Riemann from flat (all zero christoffel derivs -> all zero riemann)
var dg_chris_deriv = alloc(128);
var _dg_j = 0;
while (_dg_j < 16) { store64(dg_chris_deriv + _dg_j * 8, 0); _dg_j = _dg_j + 1; }
var dg_riemann = riemann_tensor(dg_chris, dg_chris_deriv, 2);
assert_eq(f64_to(riemann_get(dg_riemann, 2, 0, 0, 0, 1)), 0, "flat Riemann=0");
assert_eq(f64_to(riemann_get(dg_riemann, 2, 1, 0, 0, 1)), 0, "flat Riemann b=0");

# Ricci tensor (all zero)
var dg_ricci = ricci_tensor(dg_riemann, 2);
assert_eq(f64_to(ricci_get(dg_ricci, 2, 0, 0)), 0, "flat Ricci=0");

# Ricci scalar = 0
var dg_scalar = ricci_scalar(dg_ricci, dg_metric_inv, 2);
assert_eq(f64_to(dg_scalar), 0, "flat scalar=0");

# Einstein tensor (R_mn - 1/2 R g_mn, but R=0 and all R_mn=0 -> 0)
var dg_metric = alloc(32);
store64(dg_metric, F64_ONE); store64(dg_metric + 8, 0);
store64(dg_metric + 16, 0); store64(dg_metric + 24, F64_ONE);
var dg_einstein = einstein_tensor(dg_ricci, dg_metric, dg_metric_inv, 2);
assert_eq(f64_to(load64(dg_einstein)), 0, "flat Einstein=0");

# ----------------------------------------------------------------
test_group("diffgeo: wedge product");

# alpha=(1,0), beta=(0,1) -> wedge = 1
var dg_alpha = alloc(16);
store64(dg_alpha, F64_ONE); store64(dg_alpha + 8, 0);
var dg_beta = alloc(16);
store64(dg_beta, 0); store64(dg_beta + 8, F64_ONE);
var dg_w = wedge_1_1(dg_alpha, dg_beta, 2);
assert_eq(f64_to(load64(dg_w)), 1, "wedge e1^e2=1");

# Antisymmetry: alpha ^ alpha = 0
var dg_w2 = wedge_1_1(dg_alpha, dg_alpha, 2);
assert_eq(f64_to(load64(dg_w2)), 0, "wedge alpha^alpha=0");

# ================================================================
# SYMBOLIC (~15)
# ================================================================
test_group("symbolic: evaluate");

# Evaluate constant
var s_c = expr_const(f64_from(42));
var s_empty = vec_new();
assert_eq(f64_to(expr_eval(s_c, s_empty)), 42, "eval const");

# Evaluate variable
var s_x = expr_var(str_from("x"));
var s_binds = vec_new();
vec_push(s_binds, expr_bind(str_from("x"), f64_from(7)));
assert_eq(f64_to(expr_eval(s_x, s_binds)), 7, "eval var");

# Evaluate x^2 + 3 at x=2 -> 7
var s_x2 = expr_mul(s_x, s_x);
var s_e = expr_add(s_x2, expr_const(f64_from(3)));
var s_binds2 = vec_new();
vec_push(s_binds2, expr_bind(str_from("x"), f64_from(2)));
assert_eq(f64_to(expr_eval(s_e, s_binds2)), 7, "eval x^2+3 at 2");

# Evaluate sin(0) = 0
var s_sin0 = expr_sin(expr_const(0));
assert_eq(f64_to(expr_eval(s_sin0, s_empty)), 0, "eval sin(0)");

# Evaluate exp(0) = 1
var s_exp0 = expr_exp(expr_const(0));
assert_eq(f64_to(expr_eval(s_exp0, s_empty)), 1, "eval exp(0)");

# ----------------------------------------------------------------
test_group("symbolic: differentiate");

# d/dx(const) = 0
var s_dc = expr_diff(expr_const(f64_from(5)), str_from("x"));
assert_eq(f64_to(expr_eval(s_dc, s_empty)), 0, "diff const=0");

# d/dx(x) = 1
var s_dx = expr_diff(expr_var(str_from("x")), str_from("x"));
assert_eq(f64_to(expr_eval(s_dx, s_binds2)), 1, "diff x=1");

# d/dx(x^2) at x=2 -> 4
var s_dx2 = expr_simplify(expr_diff(s_x2, str_from("x")));
assert_eq(f64_to(expr_eval(s_dx2, s_binds2)), 4, "diff x^2 at 2 = 4");

# d/dx(sin(x)) at x=0 -> cos(0) = 1
var s_sin_x = expr_sin(expr_var(str_from("x")));
var s_dsin = expr_simplify(expr_diff(s_sin_x, str_from("x")));
var s_binds0 = vec_new();
vec_push(s_binds0, expr_bind(str_from("x"), 0));
assert_eq(f64_to(expr_eval(s_dsin, s_binds0)), 1, "diff sin at 0 = cos(0)=1");

# d/dx(exp(x)) at x=0 -> exp(0) = 1
var s_exp_x = expr_exp(expr_var(str_from("x")));
var s_dexp = expr_simplify(expr_diff(s_exp_x, str_from("x")));
assert_eq(f64_to(expr_eval(s_dexp, s_binds0)), 1, "diff exp at 0 = 1");

# ----------------------------------------------------------------
test_group("symbolic: simplify");

# 0 + x = x
var s_xv = expr_var(str_from("x"));
var s_zero_plus = expr_add(expr_const(0), s_xv);
var s_sp = expr_simplify(s_zero_plus);
assert_eq(expr_tag(s_sp), EXPR_VAR, "0+x -> var");

# 1 * x = x
var s_one_mul = expr_mul(expr_const(F64_ONE), s_xv);
var s_sp2 = expr_simplify(s_one_mul);
assert_eq(expr_tag(s_sp2), EXPR_VAR, "1*x -> var");

# 0 * x = 0
var s_zero_mul = expr_mul(expr_const(0), s_xv);
var s_sp3 = expr_simplify(s_zero_mul);
assert_eq(expr_tag(s_sp3), EXPR_CONST, "0*x -> const");

# x^0 = 1
var s_pow0 = expr_pow(s_xv, expr_const(0));
var s_sp4 = expr_simplify(s_pow0);
assert_eq(expr_tag(s_sp4), EXPR_CONST, "x^0 -> const");
assert_eq(f64_to(expr_eval(s_sp4, s_empty)), 1, "x^0 = 1");

# x^1 = x
var s_pow1 = expr_pow(s_xv, expr_const(F64_ONE));
var s_sp5 = expr_simplify(s_pow1);
assert_eq(expr_tag(s_sp5), EXPR_VAR, "x^1 -> var");

# --x = x (double negation)
var s_dblneg = expr_neg(expr_neg(s_xv));
var s_sp6 = expr_simplify(s_dblneg);
assert_eq(expr_tag(s_sp6), EXPR_VAR, "--x -> var");

# ----------------------------------------------------------------
test_group("symbolic: to_str");

var s_str_c = expr_to_str(expr_const(f64_from(42)));
assert(str_eq(s_str_c, str_from("42")) == 1, "to_str const 42");

var s_str_v = expr_to_str(expr_var(str_from("y")));
assert(str_eq(s_str_v, str_from("y")) == 1, "to_str var y");

# ================================================================
# AUTODIFF (~10)
# ================================================================
test_group("autodiff: x^2");

# f(x) = x^2 at x=3: val=9, deriv=6
var ad_x3 = dual_var(f64_from(3));
var ad_x3_sq = dual_mul(ad_x3, ad_x3);
assert_eq(f64_to(Dual_val(ad_x3_sq)), 9, "x^2 at 3 val=9");
assert_eq(f64_to(Dual_deriv(ad_x3_sq)), 6, "x^2 at 3 deriv=6");

# f(x) = x^2 at x=0: val=0, deriv=0
var ad_x0 = dual_var(0);
var ad_x0_sq = dual_mul(ad_x0, ad_x0);
assert_eq(f64_to(Dual_val(ad_x0_sq)), 0, "x^2 at 0 val=0");
assert_eq(f64_to(Dual_deriv(ad_x0_sq)), 0, "x^2 at 0 deriv=0");

# ----------------------------------------------------------------
test_group("autodiff: sin/cos/exp/ln/sqrt");

# sin(0)=0, deriv=cos(0)=1
var ad_sin0 = dual_sin(dual_var(0));
assert_eq(f64_to(Dual_val(ad_sin0)), 0, "sin(0) val");
assert_eq(f64_to(Dual_deriv(ad_sin0)), 1, "sin(0) deriv=cos(0)=1");

# cos(0)=1, deriv=-sin(0)=0
var ad_cos0 = dual_cos(dual_var(0));
assert_eq(f64_to(Dual_val(ad_cos0)), 1, "cos(0) val");
assert_eq(f64_to(Dual_deriv(ad_cos0)), 0, "cos(0) deriv=-sin(0)=0");

# exp(0)=1, deriv=exp(0)=1
var ad_exp0 = dual_exp(dual_var(0));
assert_eq(f64_to(Dual_val(ad_exp0)), 1, "exp(0) val");
assert_eq(f64_to(Dual_deriv(ad_exp0)), 1, "exp(0) deriv");

# ln(1)=0, deriv=1/1=1
var ad_ln1 = dual_ln(dual_var(F64_ONE));
assert_eq(f64_to(Dual_val(ad_ln1)), 0, "ln(1) val");
assert_eq(f64_to(Dual_deriv(ad_ln1)), 1, "ln(1) deriv");

# sqrt(4)=2, deriv=1/(2*2)=0.25
var ad_sqrt4 = dual_sqrt(dual_var(f64_from(4)));
assert_eq(f64_to(Dual_val(ad_sqrt4)), 2, "sqrt(4) val");
var ad_sqrt4_d = f64_to(f64_round(f64_mul(Dual_deriv(ad_sqrt4), f64_from(100))));
assert_eq(ad_sqrt4_d, 25, "sqrt(4) deriv*100=25");

# ----------------------------------------------------------------
test_group("autodiff: composition");

# f(x) = x^2 + 2x at x=3: val = 9+6 = 15, deriv = 2x+2 = 8
var ad_x = dual_var(f64_from(3));
var ad_x_sq = dual_mul(ad_x, ad_x);
var ad_2x = dual_mul(dual_const(F64_TWO), ad_x);
var ad_comp = dual_add(ad_x_sq, ad_2x);
assert_eq(f64_to(Dual_val(ad_comp)), 15, "x^2+2x at 3 val=15");
assert_eq(f64_to(Dual_deriv(ad_comp)), 8, "x^2+2x at 3 deriv=8");

# ================================================================
# INTERVAL (~10)
# ================================================================
test_group("interval: arithmetic");

var iv_a = ivl_new(f64_from(1), f64_from(3));
var iv_b = ivl_new(f64_from(2), f64_from(4));

# Add: [1,3]+[2,4] = [3,7]
var iv_add = ivl_add(iv_a, iv_b);
assert_eq(f64_to(Interval_lo(iv_add)), 3, "ivl add lo");
assert_eq(f64_to(Interval_hi(iv_add)), 7, "ivl add hi");

# Sub: [1,3]-[2,4] = [1-4, 3-2] = [-3, 1]
var iv_sub = ivl_sub(iv_a, iv_b);
assert_eq(f64_to(Interval_lo(iv_sub)), (0 - 3), "ivl sub lo");
assert_eq(f64_to(Interval_hi(iv_sub)), 1, "ivl sub hi");

# Mul: [1,3]*[2,4] = [2,12]
var iv_mul = ivl_mul(iv_a, iv_b);
assert_eq(f64_to(Interval_lo(iv_mul)), 2, "ivl mul lo");
assert_eq(f64_to(Interval_hi(iv_mul)), 12, "ivl mul hi");

# Div: [1,3]/[2,4] = [1/4, 3/2] = [0.25, 1.5]
var iv_div = ivl_div(iv_a, iv_b);
var iv_div_lo100 = f64_to(f64_round(f64_mul(Interval_lo(iv_div), f64_from(100))));
assert_eq(iv_div_lo100, 25, "ivl div lo*100=25");

# ----------------------------------------------------------------
test_group("interval: queries");

assert_eq(ivl_contains(iv_a, f64_from(2)), 1, "ivl contains 2");
assert_eq(ivl_contains(iv_a, f64_from(4)), 0, "ivl not contains 4");
assert_eq(ivl_overlaps(iv_a, iv_b), 1, "ivl overlaps");
assert_eq(f64_to(ivl_width(iv_a)), 2, "ivl width=2");
assert_eq(f64_to(ivl_midpoint(iv_a)), 2, "ivl midpoint=2");

# ----------------------------------------------------------------
test_group("interval: neg, abs, sqrt, point");

# Neg: -[1,3] = [-3,-1]
var iv_neg = ivl_neg(iv_a);
assert_eq(f64_to(Interval_lo(iv_neg)), (0 - 3), "ivl neg lo");
assert_eq(f64_to(Interval_hi(iv_neg)), (0 - 1), "ivl neg hi");

# Abs: |[-3,1]| = [0,3] (contains 0)
var iv_neg3_1 = ivl_new(f64_neg(f64_from(3)), F64_ONE);
var iv_abs = ivl_abs(iv_neg3_1);
assert_eq(f64_to(Interval_lo(iv_abs)), 0, "ivl abs lo=0");
assert_eq(f64_to(Interval_hi(iv_abs)), 3, "ivl abs hi=3");

# Sqrt: sqrt([4,9]) = [2,3]
var iv_49 = ivl_new(f64_from(4), f64_from(9));
var iv_sqrt = ivl_sqrt(iv_49);
assert_eq(f64_to(Interval_lo(iv_sqrt)), 2, "ivl sqrt lo=2");
assert_eq(f64_to(Interval_hi(iv_sqrt)), 3, "ivl sqrt hi=3");

# Point interval
var iv_pt = ivl_point(f64_from(5));
assert_eq(f64_to(ivl_width(iv_pt)), 0, "point width=0");
assert_eq(f64_to(ivl_midpoint(iv_pt)), 5, "point mid=5");

# ================================================================
# TENSOR (~10)
# ================================================================
test_group("tensor: create, get/set");

var t_shape = alloc(16);
store64(t_shape, 3); store64(t_shape + 8, 4);
var t = tensor_new(2, t_shape);
assert_eq(f64_to(tensor_get2(t, 0, 0)), 0, "tensor zero init");

tensor_set2(t, 1, 2, f64_from(42));
assert_eq(f64_to(tensor_get2(t, 1, 2)), 42, "tensor set/get");
assert_eq(f64_to(tensor_get2(t, 2, 3)), 0, "tensor other still 0");

# ----------------------------------------------------------------
test_group("tensor: kronecker delta");

assert_eq(f64_to(kronecker_delta(0, 0)), 1, "delta ii=1");
assert_eq(f64_to(kronecker_delta(1, 1)), 1, "delta jj=1");
assert_eq(f64_to(kronecker_delta(0, 1)), 0, "delta ij=0");
assert_eq(f64_to(kronecker_delta(2, 3)), 0, "delta 23=0");

# ----------------------------------------------------------------
test_group("tensor: minkowski metric");

assert_eq(f64_to(minkowski(0, 0)), 1, "eta 00=+1");
assert_eq(f64_to(minkowski(1, 1)), (0 - 1), "eta 11=-1");
assert_eq(f64_to(minkowski(2, 2)), (0 - 1), "eta 22=-1");
assert_eq(f64_to(minkowski(3, 3)), (0 - 1), "eta 33=-1");
assert_eq(f64_to(minkowski(0, 1)), 0, "eta 01=0");

# ----------------------------------------------------------------
test_group("tensor: levi-civita 3D");

assert_eq(levi_civita_3(0, 1, 2), 1, "eps 012=+1");
assert_eq(levi_civita_3(1, 2, 0), 1, "eps 120=+1");
assert_eq(levi_civita_3(2, 0, 1), 1, "eps 201=+1");
assert_eq(levi_civita_3(1, 0, 2), (0 - 1), "eps 102=-1");
assert_eq(levi_civita_3(0, 0, 1), 0, "eps repeated=0");

# ----------------------------------------------------------------
test_group("tensor: levi-civita 4D");

assert_eq(levi_civita_4(0, 1, 2, 3), 1, "eps4 0123=+1");
assert_eq(levi_civita_4(1, 0, 2, 3), (0 - 1), "eps4 1023=-1");
assert_eq(levi_civita_4(0, 0, 1, 2), 0, "eps4 repeated=0");

# ----------------------------------------------------------------
test_group("tensor: tensor_add");

var t_shape2 = alloc(16);
store64(t_shape2, 2); store64(t_shape2 + 8, 2);
var t_a = tensor_new(2, t_shape2);
tensor_set2(t_a, 0, 0, f64_from(1));
tensor_set2(t_a, 0, 1, f64_from(2));
tensor_set2(t_a, 1, 0, f64_from(3));
tensor_set2(t_a, 1, 1, f64_from(4));

var t_b = tensor_new(2, t_shape2);
tensor_set2(t_b, 0, 0, f64_from(10));
tensor_set2(t_b, 0, 1, f64_from(20));
tensor_set2(t_b, 1, 0, f64_from(30));
tensor_set2(t_b, 1, 1, f64_from(40));

var t_sum = tensor_add(t_a, t_b);
assert_eq(f64_to(tensor_get2(t_sum, 0, 0)), 11, "tensor_add [0,0]");
assert_eq(f64_to(tensor_get2(t_sum, 0, 1)), 22, "tensor_add [0,1]");
assert_eq(f64_to(tensor_get2(t_sum, 1, 0)), 33, "tensor_add [1,0]");
assert_eq(f64_to(tensor_get2(t_sum, 1, 1)), 44, "tensor_add [1,1]");

# ================================================================
var r = assert_summary();
